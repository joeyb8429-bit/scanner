            $it.SubItems.Add([string]$h.Note) | Out-Null
            $it.BackColor = [System.Drawing.Color]::FromArgb(60,0,0); $it.ForeColor = [System.Drawing.Color]::FromArgb(255,0,170)
            $lv4.Items.Add($it) | Out-Null
        }
    }
    $tp4.Controls.Add($lv4); $tab.TabPages.Add($tp4)

    $tp5 = New-Tab "Pipes ($($pipeFindings.Count))"
    $lv5 = New-DarkListView @(("Pipe Name",400),("Match",300))
    if ($pipeFindings.Count -eq 0) { Add-CleanRow $lv5 "No cheat named pipes found" }
    else {
        foreach ($p in $pipeFindings) {
            $it = New-Object System.Windows.Forms.ListViewItem([string]$p.PipeName)
            $it.SubItems.Add([string]$p.Match) | Out-Null
            $it.BackColor = [System.Drawing.Color]::FromArgb(60,0,0); $it.ForeColor = [System.Drawing.Color]::FromArgb(255,80,80)
            $lv5.Items.Add($it) | Out-Null
        }
    }
    $tp5.Controls.Add($lv5); $tab.TabPages.Add($tp5)

    $tp6 = New-Tab "Handles ($($handleFindings.Count))"
    $lv6 = New-DarkListView @(("Owner PID",80),("Owner Name",180),("Access",100),("Cheat Match",150),("Path",420))
    if ($handleFindings.Count -eq 0) { Add-CleanRow $lv6 "No unexpected processes holding Roblox open" }
    else {
        foreach ($h in $handleFindings) {
            $it = New-Object System.Windows.Forms.ListViewItem([string]$h.OwnerPID)
            $it.SubItems.Add([string]$h.OwnerName) | Out-Null
            $it.SubItems.Add([string]$h.Access)    | Out-Null
            $it.SubItems.Add([string]$(if ($h.CheatMatch) { $h.CheatMatch } else { "None" })) | Out-Null
            $it.SubItems.Add([string]$h.OwnerPath) | Out-Null
            if ($h.CheatMatch) { $it.BackColor = [System.Drawing.Color]::FromArgb(60,0,0); $it.ForeColor = [System.Drawing.Color]::FromArgb(255,80,80) }
            else { $it.ForeColor = [System.Drawing.Color]::FromArgb(255,215,0) }
            $lv6.Items.Add($it) | Out-Null
        }
    }
    $tp6.Controls.Add($lv6); $tab.TabPages.Add($tp6)

    $form.Controls.Add($tab)
    Show-FinalForm $form
}

function Show-BAMGui {
    if ($bamViewerData.Count -eq 0) { Write-Info "No BAM data to display"; return }
    $form = New-DarkForm "BAM Viewer -- $($bamViewerData.Count) entries"
    $form.Controls.Add((New-CloseBar "Red=cheat match"))
    $tab = New-Object System.Windows.Forms.TabControl
    $tab.Dock = 'Fill'; $tab.Font = New-Object System.Drawing.Font("Consolas",9)

    function New-BamTab($name) {
        $tp = New-Object System.Windows.Forms.TabPage($name)
        $tp.BackColor = [System.Drawing.Color]::FromArgb(17,24,39)
        $tp.ForeColor = [System.Drawing.Color]::FromArgb(0,212,255)
        return $tp
    }
    function Fill-BamList($lv, $data) {
        foreach ($r in ($data | Sort-Object LastRun -Descending)) {
            $item = New-Object System.Windows.Forms.ListViewItem([string]$r.LastRun)
            $item.SubItems.Add([string]$r.Path) | Out-Null
            $item.SubItems.Add([string]$r.SID)  | Out-Null
            $item.SubItems.Add([string]$(if ($r.Flagged) { $r.Match } else { "" })) | Out-Null
            if ($r.Flagged) { $item.BackColor = [System.Drawing.Color]::FromArgb(60,0,0); $item.ForeColor = [System.Drawing.Color]::FromArgb(255,80,80) }
            $lv.Items.Add($item) | Out-Null
        }
    }

    $tpAll = New-BamTab "All ($($bamViewerData.Count))"
    $lvAll = New-DarkListView @(("Last Run",170),("Path",520),("SID",180),("Match",150))
    Fill-BamList $lvAll $bamViewerData
    $tpAll.Controls.Add($lvAll); $tab.TabPages.Add($tpAll)

    $flagged = @($bamViewerData | Where-Object { $_.Flagged })
    $tpFlag = New-BamTab "Flagged ($($flagged.Count))"
    $lvFlag = New-DarkListView @(("Last Run",170),("Path",520),("SID",180),("Match",150))
    if ($flagged.Count -eq 0) { Add-CleanRow $lvFlag "No flagged BAM entries" } else { Fill-BamList $lvFlag $flagged }
    $tpFlag.Controls.Add($lvFlag); $tab.TabPages.Add($tpFlag)

    $byUser = $bamViewerData | Group-Object SID
    $tpUser = New-BamTab "By User ($($byUser.Count) SIDs)"
