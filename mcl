function DeductConfig($cat, $pts) {
    if ($configScores.Contains($cat)) {
        $configScores[$cat] = [math]::Max(0, $configScores[$cat] - $pts)
    }
}
function DeductCheat($cat, $pts) {
    if ($cheatScores.Contains($cat)) {
        $cheatScores[$cat] = [math]::Max(0, $cheatScores[$cat] - $pts)
    }
}
function Add-Finding($cat, $type, $detail, $value, $configCat, $cheatCat, $pts) {
    if (-not $findings.Contains($cat)) { return }
    $findings[$cat].Add([PSCustomObject]@{
        Type      = $type
        Detail    = $detail
        Value     = $value
        Timestamp = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    })
    if ($configCat -and $pts -gt 0) { DeductConfig $configCat $pts }
    if ($cheatCat  -and $pts -gt 0) { DeductCheat  $cheatCat  $pts }
}
function Add-Timeline($event) {
    $timeline.Add([PSCustomObject]@{
        Event = $event
        Time  = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
    })
}
function Add-FP($type, $detail, $reason) {
    $findings["FalsePositives"].Add([PSCustomObject]@{
        Type   = $type
        Detail = $detail
        Reason = $reason
    })
}

function Is-GlobalFP($str) {
    if (-not $str) { return $false }
    return $script:globalFPRegex.IsMatch($str)
}
function Is-BAMFalsePositive($path) {
    if (-not $path) { return $false }
    return $script:bamFPRegex.IsMatch($path)
}
function Is-MUIFalsePositive($entry) {
    if (-not $entry) { return $false }
    return $script:muiFPRegex.IsMatch($entry)
}
function Is-UAFalsePositive($decoded) {
    if (-not $decoded) { return $false }
    return $script:uaFPRegex.IsMatch($decoded)
}
function Is-KnownLegitDriver($name) {
    if (-not $name) { return $false }
    $l = $name.ToLower()
    foreach ($p in $knownLegitDriverPrefixes) {
        if ($l -like "$($p.ToLower())*" -or $l -eq $p.ToLower()) { return $true }
    }
    foreach ($s in $commonDriverSkipList) {
        if ($l -like "*$($s.ToLower())*") { return $true }
    }
    return $false
}

function Test-CheatMatch($str) {
    if (-not $str) { return $null }
    if (Is-GlobalFP $str) { return $null }
    $lower = $str.ToLower()
    $noExt = try { [System.IO.Path]::GetFileNameWithoutExtension($lower) } catch { $lower }
    foreach ($term in $exactTerms) {
        $t = $term.ToLower()
        if ($exactNameOnlyTerms -contains $term) {
            if ($noExt -eq $t -or $lower -eq $t) { return $term }
            continue
        }
        if ($noExt -eq $t -or $lower -eq $t) { return $term }
        if ($t.Length -gt 5 -and $lower -like "*$t*") { return $term }
    }
    return $null
}

function Test-SuspiciousMemString($str) {
    if (-not $str) { return $false }
    $sl = $str.ToLower()
    foreach ($s in $suspiciousButLikelyRobloxStrings) {
        if ($sl -eq $s.ToLower()) { return $true }
    }
    return $false
}

function UnROT13($str) {
    $result = ""
    foreach ($c in $str.ToCharArray()) {
        if ($c -match '[a-zA-Z]') {
            $base   = if ($c -cmatch '[a-z]') { [int][char]'a' } else { [int][char]'A' }
            $result += [char](([int][char]$c - $base + 13) % 26 + $base)
        } else { $result += $c }
    }
    return $result
}

function Is-SignedByRoblox($filePath) {
    try {
        $sig = Get-AuthenticodeSignature $filePath -ErrorAction Stop
        if ($sig -and $sig.Status -eq "Valid" -and $sig.SignerCertificate) {
            foreach ($signer in $knownRobloxSigners) {
                if ($sig.SignerCertificate.Subject -like "*$signer*") { return $true }
            }
        }
        return $false
    } catch { return $false }
}

function Get-FileEntropy($path) {
    try {
        $info = Get-Item $path -ErrorAction Stop
        if ($info.Length -lt 4096) { return -1.0 }
        $sample = [math]::Min([int]$info.Length, 512KB)
        $fs     = [System.IO.File]::OpenRead($path)
        $buf    = New-Object byte[] $sample
        $read   = $fs.Read($buf, 0, $sample)
        $fs.Close()
        if ($read -lt 64) { return -1.0 }
        $freq = New-Object int[] 256
        foreach ($b in $buf[0..($read - 1)]) { $freq[$b]++ }
        $entropy = 0.0
        foreach ($f in $freq) {
            if ($f -gt 0) {
                $p = $f / $read
                $entropy -= $p * [math]::Log($p, 2)
            }
        }
        return [math]::Round($entropy, 4)
    } catch { return -1.0 }
}

function Get-PrefetchTimestamps($path) {
    $times = [System.Collections.Generic.List[DateTime]]::new()
    try {
        $bytes   = [System.IO.File]::ReadAllBytes($path)
        if ($bytes.Length -lt 136) { return $times }
        $version = [System.BitConverter]::ToUInt32($bytes, 0)
        if ($version -eq 30 -or $version -eq 31) {
            for ($i = 0; $i -lt 8; $i++) {
                $offset = 128 + ($i * 8)
                if ($offset + 8 -gt $bytes.Length) { break }
                $ft = [System.BitConverter]::ToInt64($bytes, $offset)
                if ($ft -gt 0 -and $ft -lt 999999999999999999L) {
                    $times.Add([DateTime]::FromFileTimeUtc($ft).ToLocalTime())
                }
            }
        } else {
            $ft = [System.BitConverter]::ToInt64($bytes, 128)
            if ($ft -gt 0 -and $ft -lt 999999999999999999L) {
                $times.Add([DateTime]::FromFileTimeUtc($ft).ToLocalTime())
            }
        }
    } catch {}
    return $times
}

function Get-ProtectionName($protect) {
    switch ($protect -band 0xFF) {
        0x01 { return "NOACCESS" }
        0x02 { return "READONLY" }
        0x04 { return "READWRITE" }
        0x08 { return "WRITECOPY" }
        0x10 { return "EXECUTE" }
        0x20 { return "EXECUTE_READ" }
        0x40 { return "EXECUTE_READWRITE" }
        0x80 { return "EXECUTE_WRITECOPY" }
        default { return "UNKNOWN(0x$($protect.ToString('X')))" }
    }
}

function Search-MemoryRegion([byte[]]$buf, [int]$bytesRead) {
    $found = [System.Collections.Generic.List[string]]::new()
    if ($bytesRead -le 0) { return $found }
    $ascii = [System.Text.Encoding]::ASCII.GetString($buf, 0, $bytesRead).ToLower()
    $uni   = [System.Text.Encoding]::Unicode.GetString($buf, 0, $bytesRead).ToLower()
    foreach ($sig in $memoryScanStrings) {
        $sl = $sig.ToLower()
        if ($ascii.Contains($sl) -or $uni.Contains($sl)) { $found.Add($sig) }
    }
    return $found
}

function Get-ProcessAncestry($procPid) {
    $chain   = [System.Collections.Generic.List[object]]::new()
    $current = $procPid
    $visited = [System.Collections.Generic.HashSet[int]]::new()
    while ($current -gt 0 -and -not $visited.Contains($current)) {
        $visited.Add($current) | Out-Null
        try {
            $wmi = Get-WmiObject Win32_Process -Filter "ProcessId=$current" -ErrorAction Stop | Select-Object -First 1
            if ($wmi) {
                $chain.Add([PSCustomObject]@{
                    PID  = [int]$wmi.ProcessId
                    Name = $wmi.Name
                    Path = $wmi.ExecutablePath
                    PPID = [int]$wmi.ParentProcessId
                })
                $current = [int]$wmi.ParentProcessId
            } else { break }
        } catch { break }
    }
    return $chain
}

