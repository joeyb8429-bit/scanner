    # TypedPaths (Explorer address bar)
    Write-Info "Scanning Explorer TypedPaths..."
    $tpKey = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\TypedPaths"
    if (Test-Path $tpKey) {
        $props = Get-ItemProperty $tpKey -ErrorAction SilentlyContinue
        $props.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
            $val = $_.Value
            if (Is-GlobalFP $val) { return }
            $match = Test-CheatMatch $val.ToLower()
            if ($match) {
                Write-Hit "TypedPaths HIT: $val -- matches '$match'"
