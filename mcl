function Show-UnsignedDriverGui {
    $unsignedDrivers = [System.Collections.Generic.List[object]]::new()
    try {
        foreach ($drv in @(Get-WmiObject Win32_SystemDriver -ErrorAction Stop | Where-Object { $_.State -eq "Running" })) {
            $drvName = ($drv.Name -replace "\.sys$","").ToLower()
            if (Is-KnownLegitDriver $drvName) { continue }
            $path = $drv.PathName
            if (-not $path) { continue }
            $cleanPath = $path -replace '\\\\?\\.\\','' -replace '"',''
            if (Is-GlobalFP $cleanPath) { continue }
            $sig = $null
            try { $sig = Get-AuthenticodeSignature $cleanPath -ErrorAction Stop } catch {}
            $sigStatus = if ($sig) { $sig.Status.ToString() } else { "Unreadable" }
            if (-not $sig -or $sig.Status -ne "Valid") {
                $cheatMatch = Test-CheatMatch $drvName
                $inTemp = $cleanPath.ToLower() -like "*\temp\*" -or $cleanPath.ToLower() -like "*\appdata\*"
                $isByovd = $false
                foreach ($bd in $byovdDrivers) { if ($drvName -like "*$bd*") { $isByovd = $true; break } }
                $unsignedDrivers.Add([PSCustomObject]@{ Name=$drv.Name; Path=$cleanPath; SigStatus=$sigStatus; CheatMatch=if($cheatMatch){$cheatMatch}else{""}; InTemp=$inTemp; IsByovd=$isByovd; StartMode=$drv.StartMode })
            }
        }
    } catch { Write-Warn "Could not enumerate drivers for unsigned GUI" }

    if ($unsignedDrivers.Count -eq 0) { Write-OK "No unsigned running drivers found"; return }

    $form = New-DarkForm "Unsigned Driver Viewer -- $($unsignedDrivers.Count) driver(s)"
    $form.Controls.Add((New-CloseBar "Red=cheat/BYOVD/temp path  Yellow=unsigned unknown  Gray=likely benign"))
    $panel = New-Object System.Windows.Forms.Panel; $panel.Dock = 'Top'; $panel.Height = 34
    $panel.BackColor = [System.Drawing.Color]::FromArgb(15,17,23)
    $search = New-Object System.Windows.Forms.TextBox
    $search.Dock = 'Fill'; $search.Font = New-Object System.Drawing.Font("Consolas",10)
    $search.BackColor = [System.Drawing.Color]::FromArgb(22,27,39); $search.ForeColor = [System.Drawing.Color]::FromArgb(232,232,232)
    $search.Text = "Search drivers..."
    $panel.Controls.Add($search)

    $lv = New-DarkListView @(("Driver Name",180),("Sig Status",100),("Cheat Match",130),("BYOVD",60),("Temp Path",70),("Start Mode",90),("Path",460))
    $allItems = [System.Collections.Generic.List[System.Windows.Forms.ListViewItem]]::new()
    foreach ($drv in ($unsignedDrivers | Sort-Object CheatMatch -Descending)) {
        $item = New-Object System.Windows.Forms.ListViewItem([string]$drv.Name)
        $item.SubItems.Add([string]$drv.SigStatus)                              | Out-Null
        $item.SubItems.Add([string]$drv.CheatMatch)                             | Out-Null
        $item.SubItems.Add([string]$(if ($drv.IsByovd) { "YES" } else { "" }))   | Out-Null
        $item.SubItems.Add([string]$(if ($drv.InTemp)  { "YES" } else { "" }))   | Out-Null
        $item.SubItems.Add([string]$drv.StartMode)                              | Out-Null
        $item.SubItems.Add([string]$drv.Path)                                   | Out-Null
        if ($drv.CheatMatch -or $drv.IsByovd -or $drv.InTemp) { $item.BackColor = [System.Drawing.Color]::FromArgb(60,0,0); $item.ForeColor = [System.Drawing.Color]::FromArgb(255,80,80) }
        elseif ($drv.SigStatus -eq "NotSigned") { $item.ForeColor = [System.Drawing.Color]::FromArgb(255,215,0) }
        else { $item.ForeColor = [System.Drawing.Color]::FromArgb(160,160,160) }
        $allItems.Add($item)
        $lv.Items.Add($item) | Out-Null
    }
    $search.Add_TextChanged({
        $q = $search.Text.ToLower(); $lv.BeginUpdate(); $lv.Items.Clear()
        foreach ($it in $allItems) {
            if ($q -eq "" -or $q -eq "search drivers..." -or $it.Text.ToLower() -like "*$q*" -or $it.SubItems[6].Text.ToLower() -like "*$q*") {
                $lv.Items.Add($it) | Out-Null
            }
        }
        $lv.EndUpdate()
    })
    $search.Add_Enter({ if ($search.Text -eq "Search drivers...") { $search.Text = "" } })
    $search.Add_Leave({ if ($search.Text -eq "") { $search.Text = "Search drivers..." } })

    $container = New-Object System.Windows.Forms.Panel; $container.Dock = 'Fill'
    $form.Controls.Add($container); $form.Controls.Add($panel); $container.Controls.Add($lv)
    $form.KeyPreview = $true
    $form.Add_KeyDown({ param($s,$e); if ($e.KeyCode -eq [System.Windows.Forms.Keys]::Enter -and -not $search.Focused) { $form.Close() } })
    [void]$form.ShowDialog()
}

# =====================================================
# MAIN EXECUTION
# =====================================================
Write-Banner
Select-TimeRange

Write-Host "  +============================================================+" -ForegroundColor Yellow
Write-Host "  |  INSTRUCTIONS                                             |" -ForegroundColor Yellow
Write-Host "  |  FIRST SCAN : Roblox CLOSED -- saves baseline snapshot    |" -ForegroundColor Yellow
Write-Host "  |  SECOND SCAN: Open Roblox, join game, wait 1-3 min, run   |" -ForegroundColor Yellow
Write-Host "  +============================================================+" -ForegroundColor Yellow
Write-Host ""

$robloxRunning = @(Get-Process -ErrorAction SilentlyContinue | Where-Object { $robloxProcessNames -contains $_.ProcessName })
if ($robloxRunning.Count -gt 0) {
    Write-OK "Roblox detected: $($robloxRunning | ForEach-Object { "$($_.ProcessName) PID $($_.Id)" })"
    Write-Info "Memory, thread, hollow, pipe, handle, kernel, and launch chain scans will run"
} else {
    Write-Warn "Roblox not detected -- memory/thread/hollow/pipe/handle/launch chain scans will be skipped"
}
Write-Host ""

$previousSnapshot = Load-PreviousSnapshot
$runningDelta     = $false
if ($previousSnapshot) {
    Write-Host "  Previous snapshot: $($previousSnapshot.Timestamp)" -ForegroundColor Cyan
    Write-Host ""
    $response = Read-Host "  Compare against previous scan? (Y/N)"
    if ($response -match '^[Yy]') { $runningDelta = $true; Write-Info "Delta comparison will run after scanning" }
    else { Write-Info "Delta comparison skipped" }
} else {
    Write-Info "No previous snapshot -- this is your baseline scan"
    Read-Host "  Press ENTER to begin"
}
Write-Host ""

Write-Host "  Taking snapshot..." -ForegroundColor Cyan
$currentSnapshot = Get-CurrentSnapshot
Write-OK "Snapshot: BAM=$($currentSnapshot.BAM.Count) | MUICache=$($currentSnapshot.MUICache.Count) | UserAssist=$($currentSnapshot.UserAssist.Count) | Shimcache=$($currentSnapshot.Shimcache.Count) | Prefetch=$($currentSnapshot.Prefetch.Count)"
Write-Host ""
Read-Host "  Press ENTER to begin full scan"

$s1Hits  = Run-Section1
$s2Hits  = Run-Section2
$s3Hits  = Run-Section3
$s4Hits  = Run-Section4
$s5Hits  = Run-Section5
$s6Hits  = Run-Section6
$s7Hits  = Run-Section7
$rflHits = Run-RobloxFolderCheck
$memHits = Run-MemoryScan
$panHits = Run-PANScan
$krnHits = Run-KernelDriverScan
$lchHits = Run-LaunchChainScan
$logHits = Scan-RobloxLogs
$amcHits = Run-AmCacheScan

if ($runningDelta -and $previousSnapshot) {
    Compare-Snapshots $previousSnapshot $currentSnapshot
}

if (Save-Snapshot $currentSnapshot) { Write-OK "Snapshot saved: $snapshotPath" }
else { Write-Warn "Could not save snapshot" }
Write-Host ""

Show-FindingsSummary
$scores = Show-Scores

Write-Header "OPENING VIEWERS" "Cyan"

if ($deltaFindings.Count -gt 0) {
    Read-Host "  Press ENTER to open Snapshot Delta viewer ($($deltaFindings.Count) changes)"
    Show-DeltaGui
}
if ($kernelFindings.Count -gt 0) {
    Read-Host "  Press ENTER to open Kernel Driver viewer ($($kernelFindings.Count) finding(s))"
    Show-KernelGui
}
Read-Host "  Press ENTER to open Unsigned Driver viewer"
Show-UnsignedDriverGui

Read-Host "  Press ENTER to open Launch Chain viewer"
Show-LaunchChainGui

Read-Host "  Press ENTER to open Memory viewer"
Show-MemoryGui

Read-Host "  Press ENTER to open BAM viewer"
Show-BAMGui

Read-Host "  Press ENTER to open Prefetch viewer"
Show-PrefetchGui

$reportFile = Generate-Report $scores
Write-OK "Done. Report: $reportFile"
