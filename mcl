# =====================================================
# SECTION 6 -- POWERSHELL HISTORY & ENTROPY
# =====================================================
function Run-Section6 {
    Write-Header "SECTION 6 -- POWERSHELL HISTORY & ENTROPY" "Cyan"
    $hits = 0

    # PowerShell history
    Write-Info "Scanning PowerShell history files..."
    $historyPaths = [System.Collections.Generic.List[string]]::new()
    foreach ($profile in $allUserProfiles) {
        $hp = "$profile\AppData\Roaming\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt"
        if (Test-Path $hp) { $historyPaths.Add($hp) }
    }

    foreach ($hPath in $historyPaths) {
        try {
            $lines = Get-Content $hPath -ErrorAction Stop |
                Where-Object { $_.Trim() -ne "" }
            foreach ($line in $lines) {
                $lower = $line.ToLower()
                $isFP  = $false
                foreach ($fp in $psFPPatterns) { if ($lower -like "*$fp*") { $isFP = $true; break } }
                if ($isFP) { continue }

                foreach ($pattern in $remoteExecPatterns) {
                    if ($lower -like "*$($pattern.Pattern)*") {
                        Write-Warn "PS History [$($pattern.Label)]: $line"
                        Add-Finding "RegistryExecution" "PSHistory" $line $pattern.Label $null "PowerShell History" 30
                        $hits++
                        break
                    }
                }

                foreach ($sc in $suspContent) {
                    if ($lower -like "*$($sc.ToLower())*") {
                        $match = Test-CheatMatch $lower
                        if ($match) {
                            Write-Hit "PS History cheat match: $line -- matches '$match'"
                            Add-Finding "RegistryExecution" "PSHistoryCheat" $line $match $null "PowerShell History" 40
                            $hits++
                        }
                        break
                    }
                }
            }
        } catch { continue }
    }
    if ($hits -eq 0) { Write-OK "PowerShell history: No suspicious commands" }

    # Entropy scan
    Write-Info "Running entropy scan on suspicious locations..."
    $entropyScanPaths = @(
        "$env:TEMP",
        "$env:LOCALAPPDATA\Temp",
        "$env:APPDATA",
        "$env:USERPROFILE\Downloads",
        "$env:USERPROFILE\Desktop"
    )
    foreach ($sp in $entropyScanPaths) {
        if (-not (Test-Path $sp)) { continue }
        $exes = Get-ChildItem $sp -Filter "*.exe" -File -Force -ErrorAction SilentlyContinue |
            Where-Object { $_.LastWriteTime -ge $script:ScanCutoff }
        foreach ($exe in $exes) {
            if (Is-GlobalFP $exe.FullName) { continue }
            $entropy = Get-FileEntropy $exe.FullName
            if ($entropy -ge $entropyHigh) {
                Write-Hit "High entropy executable ($entropy): $($exe.FullName)"
                Add-Finding "FilesystemExecution" "HighEntropy" $exe.FullName "entropy:$entropy" $null "Entropy Scan" 30
                $entropyResults.Add([PSCustomObject]@{ Path=$exe.FullName; Entropy=$entropy; Flag="HIGH" })
                $hits++
            } elseif ($entropy -ge $entropyWarn) {
                Write-Warn "Elevated entropy executable ($entropy): $($exe.FullName)"
                $entropyResults.Add([PSCustomObject]@{ Path=$exe.FullName; Entropy=$entropy; Flag="WARN" })
            }
        }
    }
    if ($hits -eq 0) { Write-OK "Entropy scan: No high-entropy executables found" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 7 -- RECENT ACTIVITY
# Recent files, Event 4688 process creation
# =====================================================
function Run-Section7 {
    Write-Header "SECTION 7 -- RECENT ACTIVITY" "Cyan"
    $hits = 0

    # Recent files
    Write-Info "Scanning recent files..."
    $recentPath = "$env:APPDATA\Microsoft\Windows\Recent"
    if (Test-Path $recentPath) {
        $recent = Get-ChildItem $recentPath -File -Force -ErrorAction SilentlyContinue |
            Where-Object { $_.LastWriteTime -ge $script:ScanCutoff }
        foreach ($item in $recent) {
            $name  = $item.Name
            $match = Test-CheatMatch $name.ToLower()
            if ($match -and -not (Is-GlobalFP $item.FullName)) {
                Write-Hit "Recent file HIT: $name -- matches '$match'"
                Add-Finding "RecentActivity" "RecentFile" $name $match $null "Filesystem Execution" 20
                $hits++
            }
        }
        if ($hits -eq 0) { Write-OK "Recent files: No suspicious entries" }
    }

    # Event 4688 -- Process creation
    Write-Info "Scanning Event 4688 (process creation)..."
    try {
        $events4688 = Get-WinEvent -FilterHashtable @{
            LogName   = "Security"
            Id        = 4688
            StartTime = $script:ScanCutoff
        } -MaxEvents 500 -ErrorAction Stop

        foreach ($ev in $events4688) {
            try {
                $procName = $ev.Properties[5].Value
                $procPath = $ev.Properties[6].Value
                $checkStr = "$procName $procPath".ToLower()
                if (Is-GlobalFP $checkStr) { continue }
                $match = Test-CheatMatch $checkStr
                if ($match) {
                    $timeStr = $ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss")
                    Write-Hit "Event 4688 HIT: $procName at $timeStr -- matches '$match'"
                    Add-Finding "RecentActivity" "ProcessCreation4688" "$procName ($timeStr)" $match $null "Event Log Evidence" 35
                    Add-Timeline "4688: $procName matches '$match' at $timeStr"
                    $hits++
                }
            } catch { continue }
        }
        if ($hits -eq 0) { Write-OK "Event 4688: No suspicious process creation events" }
    } catch { Write-Info "Event 4688 scan skipped (audit policy or permissions)" }

    # Event 1102 -- Security log cleared
    Write-Info "Checking for Security log clear events (1102)..."
    try {
        $logClears = Get-WinEvent -FilterHashtable @{
            LogName = "Security"; Id = 1102
        } -MaxEvents 10 -ErrorAction Stop |
            Where-Object { $_.TimeCreated -ge $script:ScanCutoff }
        foreach ($ev in $logClears) {
            $clearedBy = try { $ev.Properties[1].Value } catch { "Unknown" }
            $msg = "Security log CLEARED at $($ev.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss')) by $clearedBy"
            Write-Critical $msg
            Add-Finding "RecentActivity" "LogClear" $msg "Event 1102" $null "Event Log Evidence" 50
            Add-Timeline "CRITICAL: $msg"
            $kernelFindings.Add([PSCustomObject]@{
                Type      = "SecurityLogCleared"
                Time      = $ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss")
                ClearedBy = $clearedBy
                Note      = "Security audit log wiped -- possible evasion"
            })
            DeductCheat "Event Log Evidence" 40
            $hits++
        }
        if (-not $logClears -or @($logClears).Count -eq 0) {
            Write-OK "No Security log clear events in time range"
        }
    } catch { Write-Info "Event 1102 check skipped (insufficient permissions or log unavailable)" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# ROBLOX FOLDER SCAN
# File integrity + unsigned DLL check
# =====================================================
function Run-RobloxFolderCheck {
    Write-Header "ROBLOX FOLDER INTEGRITY" "Cyan"
    $hits   = 0
    $total  = 0
    $pct    = 0

    $robloxInstalls = [System.Collections.Generic.List[string]]::new()
    foreach ($base in $officialRobloxPaths) {
        if (Test-Path $base) {
            Get-ChildItem $base -Directory -ErrorAction SilentlyContinue |
                Where-Object { $_.Name -match "^version-" } |
                ForEach-Object { $robloxInstalls.Add($_.FullName) }
        }
    }
    if ($robloxInstalls.Count -eq 0) {
        Write-Info "No Roblox installation found"
        Write-SectionResult 0
        return 0
    }

    foreach ($install in $robloxInstalls) {
        Write-Info "Scanning: $install"
        $files = @(Get-ChildItem $install -File -Recurse -Force -ErrorAction SilentlyContinue)
        $total = $files.Count
        $done  = 0
        foreach ($file in $files) {
            $done++
            if ($done % 50 -eq 0) {
                $pct = [math]::Round($done / [math]::Max($total,1) * 100)
                Write-ProgressBar "Roblox folder" $pct
            }
            $fname = $file.Name.ToLower()
            $fpath = $file.FullName

            # Known FP DLLs
            if ($robloxFolderFPFiles -contains $fname) { continue }

            # Cheat term match
            $match = Test-CheatMatch $fname
            if ($match) {
                Write-Host ""
                Write-Hit "Roblox folder HIT: $fpath -- matches '$match'"
                Add-Finding "RobloxFolder" "CheatFile" $fpath $match $null "Roblox Folder" 50
                $robloxFolderResults.Add([PSCustomObject]@{ Path=$fpath; Issue="CheatMatch"; Match=$match; Signed=$false })
                $hits++
                continue
            }

            # Unsigned DLL check
            if ($fname.EndsWith(".dll") -and -not (Is-SignedByRoblox $fpath)) {
                $isFPDll = $false
                foreach ($fp in $robloxFolderFPFiles) { if ($fname -like "*$fp*") { $isFPDll = $true; break } }
                if (-not $isFPDll) {
                    Write-Warn "Unsigned DLL in Roblox folder: $fpath"
                    Add-Finding "RobloxFolder" "UnsignedDLL" $fpath "" $null "Roblox Folder" 20
                    $robloxFolderResults.Add([PSCustomObject]@{ Path=$fpath; Issue="UnsignedDLL"; Match=""; Signed=$false })
                }
            }
        }
        Write-Host ""
    }

    if ($hits -eq 0) { Write-OK "Roblox folder: No cheat files detected" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# MEMORY SCAN ORCHESTRATOR
# =====================================================
function Run-MemoryScan {
    Write-Header "ROBLOX PROCESS MEMORY SCAN" "Cyan"
    $hits = 0

    $robloxProcs = @(Get-Process -ErrorAction SilentlyContinue |
        Where-Object { $robloxProcessNames -contains $_.ProcessName })

    if ($robloxProcs.Count -eq 0) {
        Write-Warn "No Roblox process found -- run this scan with Roblox open for memory results"
        Write-SectionResult 0
        return 0
    }

    foreach ($proc in $robloxProcs) {
        Write-Info "[1/3] Scanning memory strings: $($proc.ProcessName) (PID $($proc.Id))..."
        $memResult = Scan-RobloxProcessMemory $proc.Id $proc.ProcessName (try { $proc.MainModule.FileName } catch { "" })

        if ($memResult.Error) {
            Write-Warn "Memory scan error: $($memResult.Error)"
        } else {
            Write-Info "Regions scanned: $($memResult.Regions) | Bytes: $([math]::Round($memResult.ScannedBytes/1MB,1)) MB"
            foreach ($h in $memResult.StringHits) {
                Write-Hit "Memory HIT: '$($h.String)' @ $($h.Address) [$($h.Region)]"
                $memoryFindings.Add($h)
                Add-Finding "ProcessMemory" "MemString" $h.String $h.Address $null "Process Memory" 40
                Add-Timeline "Memory: '$($h.String)' in $($proc.ProcessName)"
                $hits++
            }
            foreach ($s in $memResult.SuspiciousHits) {
                Write-SuspHit "Memory SUSP: '$($s.String)' @ $($s.Address) [$($s.Region)]"
                $suspiciousMemFindings.Add($s)
                Add-Finding "ProcessMemory" "MemStringSusp" $s.String $s.Address $null "Process Memory" 10
            }
            foreach ($ub in $memResult.UnbackedExec) {
                Write-Warn "Unbacked exec region: $($ub.Address) [$($ub.Protection)] $($ub.SizeKB) KB"
            }
        }

        Write-Info "[2/3] Thread start address scan: $($proc.ProcessName) (PID $($proc.Id))..."
        $threads = Get-SuspiciousThreads $proc.Id
        foreach ($t in $threads) {
            Write-Hit "Suspicious thread: TID $($t.ThreadID) starts in PRIVATE exec @ $($t.StartAddr) [$($t.Protection)]"
            $threadFindings.Add($t)
            Add-Finding "ProcessMemory" "SuspThread" "TID:$($t.ThreadID)" $t.StartAddr $null "Process Memory" 45
            Add-Timeline "Suspicious thread in $($proc.ProcessName): $($t.StartAddr)"
            $hits++
        }
        if ($threads.Count -eq 0) { Write-OK "No shellcode threads detected" }

        Write-Info "[3/3] Process hollowing check: $($proc.ProcessName) (PID $($proc.Id))..."
        $hollow = Test-ProcessHollowing $proc.Id
        if ($hollow) {
            Write-Hit "Process HOLLOWING detected: $($proc.ProcessName) (PID $($proc.Id)) -- PEB ImageBase in PRIVATE memory"
            $hollowFindings.Add([PSCustomObject]@{ PID=$proc.Id; Name=$proc.ProcessName; Note="PEB ImageBase in PRIVATE memory" })
            Add-Finding "ProcessMemory" "ProcessHollowing" $proc.ProcessName "PID:$($proc.Id)" $null "Process Memory" 60
            Add-Timeline "HOLLOWING: $($proc.ProcessName) PID $($proc.Id)"
            $hits++
        } else { Write-OK "No process hollowing detected" }
    }

    # Named pipes
    Write-Info "Enumerating named pipes..."
    $pipes = Get-SuspiciousNamedPipes
    foreach ($pipe in $pipes) {
        Write-Hit "Suspicious pipe: \\.\pipe\$($pipe.PipeName) -- matches '$($pipe.Match)'"
        $pipeFindings.Add($pipe)
        Add-Finding "ProcessMemory" "SuspPipe" $pipe.PipeName $pipe.Match $null "Named Pipes" 40
        Add-Timeline "Suspicious pipe: $($pipe.PipeName)"
        $hits++
    }
    if ($pipes.Count -eq 0) { Write-OK "No suspicious named pipes found" }

    # Handle detection
    Write-Info "Scanning for non-Roblox processes with Roblox handle..."
    $handles = Get-ProcessesWithRobloxHandle
    foreach ($h in $handles) {
        Write-Hit "Handle HIT: $($h.OwnerName) (PID $($h.OwnerPID)) holds handle to Roblox PID $($h.TargetPID) [VMRead=$($h.VMRead)]"
        $handleFindings.Add($h)
        Add-Finding "ProcessMemory" "RobloxHandle" $h.OwnerName "PID:$($h.OwnerPID)" $null "Process Memory" 50
        Add-Timeline "Handle: $($h.OwnerName) -> Roblox"
        $hits++
    }
    if ($handles.Count -eq 0) { Write-OK "No suspicious handles to Roblox detected" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# PAN SCAN -- Prefetch All Names (broad pass)
# =====================================================
function Run-PANScan {
    Write-Header "PAN SCAN -- PREFETCH ALL NAMES" "Cyan"
    $hits = 0
    $pfPath = "C:\Windows\Prefetch"
    if (-not (Test-Path $pfPath)) {
        Write-Info "Prefetch directory not available"
        Write-SectionResult 0
        return 0
    }
    $pfFiles = @(Get-ChildItem $pfPath -Filter "*.pf" -File -Force -ErrorAction SilentlyContinue)
    Write-Info "Total prefetch files: $($pfFiles.Count)"
    foreach ($pf in $pfFiles) {
        $base = [System.IO.Path]::GetFileNameWithoutExtension($pf.Name)
        $exe  = if ($base -match '^(.+)-[0-9A-F]{8}$') { $Matches[1] } else { $base }
        if (Is-GlobalFP $exe) { continue }
        $match = Test-CheatMatch $exe.ToLower()
        if ($match) {
            $ts      = Get-PrefetchTimestamps $pf.FullName
            $lastRun = if ($ts.Count -gt 0) { $ts[0].ToString("yyyy-MM-dd HH:mm:ss") } else { $pf.LastWriteTime.ToString("yyyy-MM-dd HH:mm:ss") }
            Write-Hit "PAN HIT: $exe (last run: $lastRun) -- matches '$match'"
            Add-Finding "CheatArtifacts" "PANScan" $exe $match $null "Cheat Files Found" 35
            Add-Timeline "PAN: $exe matches '$match'"
            $hits++
        }
    }
    if ($hits -eq 0) { Write-OK "PAN scan: No cheat executables in prefetch (all time)" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# KERNEL DRIVER SCAN
# Event 7045, loaded drivers, BYOVD, Memory Integrity
# blocked loads, near-Roblox timing
# =====================================================
function Run-KernelDriverScan {
    Write-Header "KERNEL DRIVER SCAN" "Cyan"
    $hits = 0

    # Event 7045 -- new service/driver installs
    Write-Info "Scanning Event 7045 (new service installs)..."
    try {
        $events = Get-WinEvent -FilterHashtable @{
            LogName   = "System"
            Id        = 7045
            StartTime = $script:ScanCutoff
        } -MaxEvents 200 -ErrorAction Stop

        foreach ($ev in $events) {
            $svcName = try { $ev.Properties[0].Value } catch { "" }
            $svcFile = try { $ev.Properties[1].Value } catch { "" }
            $svcType = try { $ev.Properties[3].Value } catch { "" }
            if (-not $svcName) { continue }
            $isKernel = $svcType -like "*kernel*"
            $checkStr = "$svcName $svcFile".ToLower()
            if (Is-GlobalFP $checkStr) { continue }

            foreach ($byovd in $byovdDrivers) {
                if ($checkStr -like "*$byovd*") {
                    Write-KernelHit "Event 7045 BYOVD: '$svcName' matches '$byovd' at $($ev.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))"
                    Add-Finding "KernelDrivers" "BYOVD-7045" $svcName $byovd $null "Kernel Drivers" 70
                    $kernelFindings.Add([PSCustomObject]@{ Type="BYOVD-Install"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Matched BYOVD list: $byovd" })
                    Add-Timeline "BYOVD driver install: $svcName"
                    $hits++
                }
            }

            $match = Test-CheatMatch $checkStr
            if ($match) {
                Write-KernelHit "Event 7045 cheat service: '$svcName' matches '$match'"
                Add-Finding "KernelDrivers" "CheatService-7045" $svcName $match $null "Kernel Drivers" 50
                $kernelFindings.Add([PSCustomObject]@{ Type="CheatService"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Cheat match: $match" })
                $hits++
            } elseif ($isKernel -and -not (Is-KnownLegitDriver $svcName)) {
                Write-Warn "Unknown kernel driver installed: $svcName ($svcFile)"
                Add-Finding "KernelDrivers" "UnknownKernelDriver" $svcName $svcFile $null "Kernel Drivers" 20
                $kernelFindings.Add([PSCustomObject]@{ Type="UnknownKernel"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Unknown kernel driver" })
            }
        }
        if ($hits -eq 0) { Write-OK "Event 7045: No suspicious driver installs" }
    } catch { Write-Info "Event 7045 scan skipped" }

    # Loaded drivers enumeration
    Write-Info "Enumerating currently loaded drivers..."
    try {
        $drivers = Get-WmiObject Win32_SystemDriver -ErrorAction Stop
        foreach ($drv in $drivers) {
            $drvName = ($drv.Name -replace "\.sys$","").ToLower()
            $drvPath = $drv.PathName
            if (Is-KnownLegitDriver $drvName) { continue }
            if (Is-GlobalFP $drvPath) { continue }
            if ($byovdDrivers -contains $drvName) {
                Write-KernelHit "LOADED BYOVD driver: $drvName ($drvPath)"
                Add-Finding "KernelDrivers" "BYOVD-Loaded" $drvName $drvPath $null "Kernel Drivers" 80
                $kernelFindings.Add([PSCustomObject]@{ Type="BYOVD-Loaded"; Name=$drvName; File=$drvPath; Time="NOW"; Note="Currently loaded BYOVD driver" })
                Add-Timeline "CRITICAL: BYOVD driver loaded: $drvName"
                $hits++
            }
        }
    } catch { Write-Info "Driver enumeration skipped" }

    # WMI BYOVD check
    Write-Info "Checking WMI for BYOVD driver remnants..."
    try {
        $wmiDrivers = Get-WmiObject Win32_PnPSignedDriver -ErrorAction Stop |
            Where-Object { $_.DriverName }
        foreach ($d in $wmiDrivers) {
            $dName = ($d.DriverName -replace "\.sys$","").ToLower()
            if ($byovdDrivers -contains $dName) {
                Write-KernelHit "WMI BYOVD driver: $dName"
                Add-Finding "KernelDrivers" "BYOVD-WMI" $dName "" $null "Kernel Drivers" 60
                $hits++
            }
        }
    } catch {}

    # Memory Integrity blocked loads (Event 3077)
    Write-Info "Checking Memory Integrity blocked driver loads (Event 3077)..."
    try {
        $blockedLoads = Get-WinEvent -FilterHashtable @{
            LogName   = "Microsoft-Windows-CodeIntegrity/Operational"
            Id        = 3077
            StartTime = $script:ScanCutoff
        } -MaxEvents 50 -ErrorAction Stop
        foreach ($ev in $blockedLoads) {
            $drvFile = try { $ev.Properties[0].Value } catch { "Unknown" }
            Write-Warn "Memory Integrity BLOCKED: $drvFile at $($ev.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))"
            Add-Finding "KernelDrivers" "MIBlocked" $drvFile "" $null "Kernel Drivers" 30
            $kernelFindings.Add([PSCustomObject]@{ Type="MI-Blocked"; Name=$drvFile; File=$drvFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Blocked by Memory Integrity" })
            $hits++
        }
    } catch {}

    if ($hits -eq 0) { Write-OK "Kernel drivers: No BYOVD or suspicious installs detected" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# LAUNCH CHAIN SCAN
# =====================================================
function Run-LaunchChainScan {
    Write-Header "ROBLOX LAUNCH CHAIN VALIDATION" "Cyan"
    $hits = 0

    $robloxProcs = @(Get-Process -ErrorAction SilentlyContinue |
        Where-Object { $robloxProcessNames -contains $_.ProcessName })

    if ($robloxProcs.Count -eq 0) {
        Write-Info "Roblox not running -- launch chain check skipped"
        Write-SectionResult 0
        return 0
    }

    foreach ($proc in $robloxProcs) {
        $chain = Get-ProcessAncestry $proc.Id
        Write-Info "Launch chain for $($proc.ProcessName) (PID $($proc.Id)):"
        foreach ($link in $chain) {
            Write-Info "  -> $($link.Name) (PID $($link.PID)) : $($link.Path)"
        }

        # Check executable path is official
        $procPath = try { $proc.MainModule.FileName } catch { "" }
        if ($procPath) {
            $isOfficial = $false
            foreach ($op in $officialRobloxPaths) {
                if ($procPath.ToLower().StartsWith($op.ToLower())) { $isOfficial = $true; break }
            }
            if (-not $isOfficial) {
                Write-LaunchHit "Roblox running from non-official path: $procPath"
                Add-Finding "LaunchChain" "NonOfficialPath" $procPath "" $null "Launch Chain" 50
                $launchChainFindings.Add([PSCustomObject]@{ Issue="NonOfficialPath"; Detail=$procPath; PID=$proc.Id })
                Add-Timeline "Roblox non-official path: $procPath"
                $hits++
            } else { Write-OK "Roblox path is official: $procPath" }
        }

        # Check parent process
        if ($chain.Count -ge 2) {
            $parent     = $chain[1]
            $parentName = $parent.Name.ToLower()
            $parentPath = $parent.Path

            $isKnownLauncher = $false
            foreach ($lnch in $knownThirdPartyLaunchers) {
                if ($parentName -like "*$($lnch.ToLower())*") { $isKnownLauncher = $true; break }
            }

            $neutralParents = @("explorer","cmd","powershell","pwsh","taskmgr","services","svchost")
            $isNeutral      = $neutralParents -contains $parentName

            if (-not $isNeutral -and -not $isKnownLauncher) {
                $match = Test-CheatMatch $parentName
                if ($match) {
                    Write-LaunchHit "Suspicious parent process: $($parent.Name) (PID $($parent.PID)) -- matches '$match'"
                    Add-Finding "LaunchChain" "SuspParent" $parent.Name $match $null "Launch Chain" 60
                    $launchChainFindings.Add([PSCustomObject]@{ Issue="SuspParent"; Detail="$($parent.Name) PID $($parent.PID)"; PID=$proc.Id })
                    $hits++
                } else {
                    Write-Warn "Unexpected parent: $($parent.Name) ($parentPath)"
                    Add-Finding "LaunchChain" "UnexpectedParent" $parent.Name $parentPath $null "Launch Chain" 20
                    $launchChainFindings.Add([PSCustomObject]@{ Issue="UnexpectedParent"; Detail="$($parent.Name) PID $($parent.PID)"; PID=$proc.Id })
                }
            } else {
                Write-OK "Parent process acceptable: $($parent.Name)"
            }
        }
    }

    if ($hits -eq 0) { Write-OK "Launch chain: No suspicious ancestry detected" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# ROBLOX LOG SCAN
# =====================================================
function Scan-RobloxLogs {
    Write-Header "ROBLOX LOG FILE SCAN" "Cyan"
    $hits    = 0
    $logRoot = "$env:LOCALAPPDATA\Roblox\logs"
    if (-not (Test-Path $logRoot)) {
        Write-Info "Roblox log directory not found"
        Write-SectionResult 0
        return 0
    }

    $logFiles = @(Get-ChildItem $logRoot -File -Filter "*.log" -ErrorAction SilentlyContinue |
        Where-Object { $_.LastWriteTime -ge $script:ScanCutoff } |
        Sort-Object LastWriteTime -Descending |
        Select-Object -First 10)

    Write-Info "Log files to scan: $($logFiles.Count)"
    foreach ($log in $logFiles) {
        try {
            $content = Get-Content $log.FullName -ErrorAction Stop
            foreach ($line in $content) {
                $lower = $line.ToLower()
                foreach ($marker in $robloxLogCheatMarkers) {
                    if ($lower -like "*$($marker.ToLower())*") {
                        Write-Hit "Log HIT in $($log.Name): $line"
                        Add-Finding "CheatArtifacts" "RobloxLog" $log.Name $line $null "Roblox Logs" 30
                        Add-Timeline "Roblox log hit: $line"
                        $hits++
                        break
                    }
                }
            }
        } catch { continue }
    }
    if ($hits -eq 0) { Write-OK "Roblox logs: No cheat markers found" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# AMCACHE SCAN (VSS)
# =====================================================
function Run-AmCacheScan {
    Write-Header "AMCACHE SCAN (via VSS)" "Cyan"
    $hits = 0

    $shadow = Get-WmiObject Win32_ShadowCopy -ErrorAction SilentlyContinue |
        Sort-Object InstallDate -Descending |
        Select-Object -First 1

    if (-not $shadow) {
        Write-Info "No VSS shadow copies found -- AmCache scan skipped"
        Write-Info "AmCache is locked by the OS while Windows is running"
        Write-SectionResult 0
        return 0
    }

    $shadowDevice = $shadow.DeviceObject
    $hiveShadow   = "$shadowDevice\Windows\AppCompat\Programs\Amcache.hve"
    $mountKey     = "HKLM\TempAmCache_CheatScan"
    $mountPath    = "HKLM:\TempAmCache_CheatScan"
    $mounted      = $false

    try {
        Write-Info "Shadow copy found: $($shadow.InstallDate)"
        Write-Info "Mounting AmCache hive..."
        $regResult = reg load $mountKey $hiveShadow 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Warn "Failed to mount AmCache hive: $regResult"
            Write-SectionResult 0
            return 0
        }
        $mounted = $true

        $appFilePath = "$mountPath\Root\InventoryApplicationFile"
        if (Test-Path $appFilePath) {
            $entries = Get-ChildItem $appFilePath -ErrorAction SilentlyContinue
            Write-Info "AmCache entries: $($entries.Count)"
            foreach ($entry in $entries) {
                try {
                    $props   = Get-ItemProperty $entry.PSPath -ErrorAction SilentlyContinue
                    $name    = $props.Name
                    $path    = $props.LowerCaseLongPath
                    if (-not $name -and -not $path) { continue }
                    $checkStr = "$name $path".ToLower()
                    if (Is-GlobalFP $checkStr) { continue }
                    $match = Test-CheatMatch $checkStr
                    if ($match) {
                        $detail = "AmCache HIT: '$name' at '$path' (matched '$match')"
                        Write-Hit $detail
                        Add-Finding "CheatArtifacts" "AmCache-Hit" $detail $path $null "Cheat Files Found" 35
                        Add-Timeline "AmCache: $detail"
                        $hits++
                    }
                } catch { continue }
            }
        } else { Write-Info "InventoryApplicationFile key not found in shadow hive" }

        $drvPath = "$mountPath\Root\InventoryDriverBinary"
        if (Test-Path $drvPath) {
            $drvEntries = Get-ChildItem $drvPath -ErrorAction SilentlyContinue
            foreach ($entry in $drvEntries) {
                try {
                    $props   = Get-ItemProperty $entry.PSPath -ErrorAction SilentlyContinue
                    $drvName = ($props.DriverName -replace "\.sys$","").ToLower()
                    if (-not $drvName) { continue }
                    if ($byovdDrivers -contains $drvName) {
                        $detail = "AmCache BYOVD driver: '$drvName'"
                        Write-KernelHit $detail
                        Add-Finding "KernelDrivers" "AmCache-BYOVD" $detail $drvName $null "Kernel Drivers" 50
                        $hits++
                    }
                } catch { continue }
            }
        }

        if ($hits -eq 0) { Write-OK "AmCache: No cheat artifacts found" }

    } catch {
        Write-Warn "AmCache scan error: $_"
    } finally {
        if ($mounted) {
            [GC]::Collect()
            Start-Sleep -Milliseconds 500
            reg unload $mountKey 2>&1 | Out-Null
            if ($LASTEXITCODE -ne 0) {
                Write-Warn "AmCache hive did not unmount cleanly -- reboot may clear it"
            }
        }
    }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SCORES & FINDINGS SUMMARY
# =====================================================
function Show-FindingsSummary {
    Write-Header "FINDINGS SUMMARY" "Magenta"
    $totalHits = 0
    foreach ($cat in $findings.Keys) {
        $count = $findings[$cat].Count
        if ($count -gt 0 -and $cat -ne "FalsePositives") {
            Write-Host "  $cat : $count finding(s)" -ForegroundColor $(if ($count -gt 0) { "Magenta" } else { "Green" })
            $totalHits += $count
        }
    }
    Write-Host ""
    Write-Host "  Total findings : $totalHits" -ForegroundColor $(if ($totalHits -gt 0) { "Magenta" } else { "Green" })
    Write-Host "  False positives: $($findings['FalsePositives'].Count)" -ForegroundColor DarkGray
    Write-Host ""
}

function Show-Scores {
    Write-Header "SCORES" "Cyan"

    Write-Host "  [Configuration]" -ForegroundColor Yellow
    foreach ($k in $configScores.Keys) {
        $v   = $configScores[$k]
        $col = if ($v -ge 80) { "Green" } elseif ($v -ge 50) { "Yellow" } else { "Red" }
        Write-Host "    $k : $v / 100" -ForegroundColor $col
    }
    Write-Host ""
    Write-Host "  [Cheat Detection]" -ForegroundColor Yellow
    foreach ($k in $cheatScores.Keys) {
        $v   = $cheatScores[$k]
        $col = if ($v -ge 80) { "Green" } elseif ($v -ge 50) { "Yellow" } else { "Red" }
        Write-Host "    $k : $v / 100" -ForegroundColor $col
    }

    $configAvg = [math]::Round(($configScores.Values | Measure-Object -Average).Average, 1)
    $cheatAvg  = [math]::Round(($cheatScores.Values  | Measure-Object -Average).Average, 1)
    Write-Host ""
    Write-Host "  Config score : $configAvg / 100" -ForegroundColor $(if ($configAvg -ge 80) { "Green" } elseif ($configAvg -ge 50) { "Yellow" } else { "Red" })
    Write-Host "  Cheat score  : $cheatAvg / 100"  -ForegroundColor $(if ($cheatAvg  -ge 80) { "Green" } elseif ($cheatAvg  -ge 50) { "Yellow" } else { "Red" })
    Write-Host ""
}

# =====================================================
# HTML REPORT
# =====================================================
function Generate-Report {
    $configAvg = [math]::Round(($configScores.Values | Measure-Object -Average).Average, 1)
    $cheatAvg  = [math]::Round(($cheatScores.Values  | Measure-Object -Average).Average, 1)
    $totalHits = ($findings.Keys | Where-Object { $_ -ne "FalsePositives" } | ForEach-Object { $findings[$_].Count } | Measure-Object -Sum).Sum

    $rowsHtml = ""
    foreach ($cat in $findings.Keys) {
        if ($cat -eq "FalsePositives") { continue }
        foreach ($f in $findings[$cat]) {
            $rowsHtml += "<tr><td>$cat</td><td>$($f.Type)</td><td>$($f.Detail)</td><td>$($f.Value)</td><td>$($f.Timestamp)</td></tr>`n"
        }
    }

    $configRows = ""
    foreach ($k in $configScores.Keys) {
        $v = $configScores[$k]
        $color = if ($v -ge 80) { "#00cc66" } elseif ($v -ge 50) { "#ffaa00" } else { "#ff4444" }
        $configRows += "<tr><td>$k</td><td style='color:$color'>$v / 100</td></tr>`n"
    }
    $cheatRows = ""
    foreach ($k in $cheatScores.Keys) {
        $v = $cheatScores[$k]
        $color = if ($v -ge 80) { "#00cc66" } elseif ($v -ge 50) { "#ffaa00" } else { "#ff4444" }
        $cheatRows += "<tr><td>$k</td><td style='color:$color'>$v / 100</td></tr>`n"
    }

    $memRowsHtml = ""
    foreach ($m in $memoryFindings) {
        $memRowsHtml += "<tr><td>$($m.String)</td><td>$($m.Address)</td><td>$($m.Region)</td></tr>`n"
    }
    $suspMemRowsHtml = ""
    foreach ($m in $suspiciousMemFindings) {
        $suspMemRowsHtml += "<tr><td>$($m.String)</td><td>$($m.Address)</td><td>$($m.Region)</td></tr>`n"
    }
    $deltaRowsHtml = ""
    foreach ($d in $deltaFindings) {
        $color = switch ($d.Change) { "ADDED-HIT" { "#ff44aa" } "DELETED" { "#ffaa00" } default { "#4499ff" } }
        $deltaRowsHtml += "<tr style='color:$color'><td>$($d.Category)</td><td>$($d.Change)</td><td>$($d.Entry)</td><td>$($d.Note)</td></tr>`n"
    }

    $html = @"
<!DOCTYPE html>
<html>
<head>
<meta charset='UTF-8'>
<title>Roblox Cheat Scanner v4.4 Report</title>
<style>
  body { background:#111; color:#eee; font-family:Consolas,monospace; padding:20px; }
  h1 { color:#00ccff; }
  h2 { color:#aaa; border-bottom:1px solid #333; padding-bottom:4px; }
  table { width:100%; border-collapse:collapse; margin-bottom:20px; }
  th { background:#222; color:#00ccff; padding:6px; text-align:left; }
  td { padding:5px; border-bottom:1px solid #222; font-size:12px; word-break:break-all; }
  .card { background:#1a1a1a; border:1px solid #333; border-radius:6px; padding:16px; margin-bottom:16px; display:inline-block; min-width:180px; margin-right:12px; }
  .card-title { color:#888; font-size:11px; }
  .card-val { font-size:28px; font-weight:bold; }
  .hit { color:#ff44aa; }
  .warn { color:#ffaa00; }
  .ok { color:#00cc66; }
</style>
</head>
<body>
<h1>Roblox Cheat Scanner v4.4</h1>
<p>Computer: <b>$env:COMPUTERNAME</b> | User: <b>$env:USERNAME</b> | Time: <b>$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')</b></p>
<div>
  <div class='card'><div class='card-title'>Total Findings</div><div class='card-val $(if ($totalHits -gt 0) {"hit"} else {"ok"})'>$totalHits</div></div>
  <div class='card'><div class='card-title'>Config Score</div><div class='card-val $(if ($configAvg -ge 80) {"ok"} elseif ($configAvg -ge 50) {"warn"} else {"hit"})'>$configAvg</div></div>
  <div class='card'><div class='card-title'>Cheat Score</div><div class='card-val $(if ($cheatAvg -ge 80) {"ok"} elseif ($cheatAvg -ge 50) {"warn"} else {"hit"})'>$cheatAvg</div></div>
  <div class='card'><div class='card-title'>Memory Hits</div><div class='card-val $(if ($memoryFindings.Count -gt 0) {"hit"} else {"ok"})'>$($memoryFindings.Count)</div></div>
  <div class='card'><div class='card-title'>Delta Findings</div><div class='card-val $(if ($deltaFindings.Count -gt 0) {"warn"} else {"ok"})'>$($deltaFindings.Count)</div></div>
</div>
<h2>All Findings</h2>
<table><tr><th>Category</th><th>Type</th><th>Detail</th><th>Value</th><th>Timestamp</th></tr>$rowsHtml</table>
<h2>Score Breakdown</h2>
<table><tr><th>Config Category</th><th>Score</th></tr>$configRows</table>
<table><tr><th>Cheat Category</th><th>Score</th></tr>$cheatRows</table>
<h2>Memory String Hits</h2>
<table><tr><th>String</th><th>Address</th><th>Region</th></tr>$memRowsHtml</table>
<h2>Suspicious Memory (Roblox API)</h2>
<table><tr><th>String</th><th>Address</th><th>Region</th></tr>$suspMemRowsHtml</table>
<h2>Snapshot Delta</h2>
<table><tr><th>Category</th><th>Change</th><th>Entry</th><th>Note</th></tr>$deltaRowsHtml</table>
</body>
</html>
"@
    $html | Out-File $reportPath -Encoding UTF8 -Force
    return $reportPath
}

