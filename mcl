# WIN32 DETECTION FUNCTIONS
# =====================================================
function Get-SuspiciousThreads($targetPid) {
    $results = [System.Collections.Generic.List[object]]::new()
    $snap    = [Win32Thread]::CreateToolhelp32Snapshot([Win32Thread]::TH32CS_SNAPTHREAD, 0)
    if ($snap -eq [IntPtr]::Zero -or $snap.ToInt64() -eq -1) { return $results }
    try {
        $entry        = New-Object Win32Thread+THREADENTRY32
        $entry.dwSize = [uint32][System.Runtime.InteropServices.Marshal]::SizeOf($entry)
        $hProc        = [Win32Mem]::OpenProcess(
            [Win32Mem]::PROCESS_VM_READ -bor [Win32Mem]::PROCESS_QUERY_INFORMATION, $false, $targetPid)
        if ($hProc -eq [IntPtr]::Zero) { return $results }
        try {
            $ok = [Win32Thread]::Thread32First($snap, [ref]$entry)
            while ($ok) {
                if ([int]$entry.th32OwnerProcessID -eq $targetPid) {
                    $hThread = [Win32Thread]::OpenThread([Win32Thread]::THREAD_QUERY_INFORMATION, $false, $entry.th32ThreadID)
                    if ($hThread -ne [IntPtr]::Zero -and $hThread.ToInt64() -ne -1) {
                        try {
                            $startAddr = [IntPtr]::Zero
                            $retLen    = 0
                            $status    = [Win32Thread]::NtQueryInformationThread($hThread, 9, [ref]$startAddr, [IntPtr]::Size, [ref]$retLen)
                            if ($status -eq 0 -and $startAddr -ne [IntPtr]::Zero) {
                                $mbi     = New-Object Win32Mem+MEMORY_BASIC_INFORMATION
                                $mbiSize = [uint32][System.Runtime.InteropServices.Marshal]::SizeOf($mbi)
                                $qr      = [Win32Mem]::VirtualQueryEx($hProc, $startAddr, [ref]$mbi, $mbiSize)
                                if ($qr -gt 0) {
                                    $isPrivate = $mbi.Type -eq [Win32Mem]::MEM_PRIVATE
                                    $isExec    = ($mbi.Protect -band 0xF0) -ne 0
                                    $notGuard  = ($mbi.Protect -band [Win32Mem]::PAGE_GUARD) -eq 0
                                    if ($isPrivate -and $isExec -and $notGuard) {
                                        $results.Add([PSCustomObject]@{
                                            ThreadID   = $entry.th32ThreadID
                                            StartAddr  = "0x$($startAddr.ToInt64().ToString('X16'))"
                                            Protection = Get-ProtectionName $mbi.Protect
                                            RegionKB   = [math]::Round($mbi.RegionSize.ToInt64() / 1KB, 1)
                                        })
                                    }
                                }
                            }
                        } finally { [Win32Thread]::CloseHandle($hThread) | Out-Null }
                    }
                }
                $ok = [Win32Thread]::Thread32Next($snap, [ref]$entry)
            }
        } finally { [Win32Mem]::CloseHandle($hProc) | Out-Null }
    } finally { [Win32Mem]::CloseHandle($snap) | Out-Null }
    return $results
}

function Test-ProcessHollowing($procPid) {
    $hProc = [Win32Mem]::OpenProcess(
        [Win32Mem]::PROCESS_VM_READ -bor [Win32Mem]::PROCESS_QUERY_INFORMATION, $false, $procPid)
    if ($hProc -eq [IntPtr]::Zero) { return $false }
    try {
        $pbi    = New-Object Win32Hollow+PROCESS_BASIC_INFORMATION
        $retLen = 0
        $status = [Win32Hollow]::NtQueryInformationProcess(
            $hProc, 0, [ref]$pbi, [System.Runtime.InteropServices.Marshal]::SizeOf($pbi), [ref]$retLen)
        if ($status -ne 0 -or $pbi.PebBaseAddress -eq [IntPtr]::Zero) { return $false }
        $pebImageOffset = [IntPtr]($pbi.PebBaseAddress.ToInt64() + 0x10)
        $imageBaseBuf   = New-Object byte[] 8
        $br             = 0
        $ok = [Win32Mem]::ReadProcessMemory($hProc, $pebImageOffset, $imageBaseBuf, 8, [ref]$br)
        if (-not $ok -or $br -lt 8) { return $false }
        $imageBase = [IntPtr][System.BitConverter]::ToInt64($imageBaseBuf, 0)
        if ($imageBase -eq [IntPtr]::Zero) { return $false }
        $mbi     = New-Object Win32Mem+MEMORY_BASIC_INFORMATION
        $mbiSize = [uint32][System.Runtime.InteropServices.Marshal]::SizeOf($mbi)
        $qr      = [Win32Mem]::VirtualQueryEx($hProc, $imageBase, [ref]$mbi, $mbiSize)
        if ($qr -eq 0) { return $false }
        return $mbi.Type -eq [Win32Mem]::MEM_PRIVATE
    } finally { [Win32Mem]::CloseHandle($hProc) | Out-Null }
}

function Get-SuspiciousNamedPipes {
    $results = [System.Collections.Generic.List[object]]::new()
    try {
        $pipes = [System.IO.Directory]::GetFiles("\\.\pipe\") |
            ForEach-Object { [System.IO.Path]::GetFileName($_).ToLower() }
    } catch { return $results }
    foreach ($pipe in $pipes) {
        $matched = $null
        foreach ($cp in $cheatPipeNames) {
            if ($pipe -like "*$($cp.ToLower())*") { $matched = $cp; break }
        }
        if (-not $matched) {
            foreach ($gp in $genericSuspPipeNames) {
                if ($pipe -like "*$($gp.ToLower())*") { $matched = "(generic: $gp)"; break }
            }
        }
        if ($matched) { $results.Add([PSCustomObject]@{ PipeName = $pipe; Match = $matched }) }
    }
    return $results
}

function Get-ProcessesWithRobloxHandle {
    $results    = [System.Collections.Generic.List[object]]::new()
    $robloxPids = @(Get-Process -ErrorAction SilentlyContinue |
        Where-Object { $robloxProcessNames -contains $_.ProcessName } |
        Select-Object -ExpandProperty Id)
    if ($robloxPids.Count -eq 0) { return $results }
    if (-not ([Management.Automation.PSTypeName]'Win32Handle').Type) { return $results }
    try {
        $bufSize = 1MB
        $buf     = [System.Runtime.InteropServices.Marshal]::AllocHGlobal($bufSize)
        try {
            $retLen = 0
            $status = [Win32Handle]::NtQuerySystemInformation([Win32Handle]::SystemHandleInformation, $buf, $bufSize, [ref]$retLen)
            if ($status -eq -1073741820 -and $retLen -gt 0) {
                [System.Runtime.InteropServices.Marshal]::FreeHGlobal($buf)
                $bufSize = $retLen + 0x10000
                $buf     = [System.Runtime.InteropServices.Marshal]::AllocHGlobal($bufSize)
                $status  = [Win32Handle]::NtQuerySystemInformation([Win32Handle]::SystemHandleInformation, $buf, $bufSize, [ref]$retLen)
            }
            if ($status -ne 0) { return $results }
            $handleCount = [System.Runtime.InteropServices.Marshal]::ReadInt32($buf, 0)
            $handleSize  = [System.Runtime.InteropServices.Marshal]::SizeOf([Win32Handle+SYSTEM_HANDLE])
            $ptr         = [IntPtr]($buf.ToInt64() + 4)
            $currentProc = [Win32Handle]::GetCurrentProcess()
            $seen        = [System.Collections.Generic.HashSet[string]]::new()
            for ($i = 0; $i -lt $handleCount; $i++) {
                $sh  = [System.Runtime.InteropServices.Marshal]::PtrToStructure($ptr, [type][Win32Handle+SYSTEM_HANDLE])
                $ptr = [IntPtr]($ptr.ToInt64() + $handleSize)
                if ($sh.ObjectTypeNumber -ne 7) { continue }
                $vmRead  = ($sh.GrantedAccess -band 0x0010) -ne 0
                $qInfo   = ($sh.GrantedAccess -band 0x0400) -ne 0
                if (-not ($vmRead -or $qInfo)) { continue }
                $ownerPid = [int]$sh.ProcessId
                if ($robloxPids -contains $ownerPid) { continue }
                $hOwner = [Win32Handle]::OpenProcess(0x0040, $false, $ownerPid)
                if ($hOwner -eq [IntPtr]::Zero) { continue }
                try {
                    $dupHandle = [IntPtr]::Zero
                    $dup = [Win32Handle]::DuplicateHandle($hOwner, [IntPtr]$sh.Handle, $currentProc, [ref]$dupHandle, 0x0400, $false, 0)
                    if (-not $dup -or $dupHandle -eq [IntPtr]::Zero) { continue }
                    try {
                        $targetPid = [Win32Handle]::GetProcessId($dupHandle)
                        if ($robloxPids -contains $targetPid) {
                            $key = "$ownerPid-$targetPid"
                            if ($seen.Add($key)) {
                                $ownerProc = Get-Process -Id $ownerPid -ErrorAction SilentlyContinue
                                $ownerName = if ($ownerProc) { $ownerProc.ProcessName } else { "(pid $ownerPid)" }
                                $ownerPath = ""
                                try { $ownerPath = $ownerProc.MainModule.FileName } catch {}
                                if (-not (Is-GlobalFP $ownerPath) -and
                                    $ownerName -notin @("lsass","svchost","MsMpEng","csrss","winlogon","services","smss")) {
                                    $results.Add([PSCustomObject]@{
                                        OwnerPID  = $ownerPid
                                        OwnerName = $ownerName
                                        OwnerPath = $ownerPath
                                        TargetPID = $targetPid
                                        Access    = "0x$($sh.GrantedAccess.ToString('X'))"
                                        VMRead    = $vmRead
                                        QueryInfo = $qInfo
                                    })
                                }
                            }
                        }
                    } finally { [Win32Handle]::CloseHandle($dupHandle) | Out-Null }
                } finally { [Win32Handle]::CloseHandle($hOwner) | Out-Null }
            }
        } finally { [System.Runtime.InteropServices.Marshal]::FreeHGlobal($buf) }
    } catch {}
    return $results
}

function Scan-RobloxProcessMemory($procPid, $pname, $ppath) {
    $res = [PSCustomObject]@{
        PID            = $procPid
        Name           = $pname
        Path           = $ppath
        StringHits     = [System.Collections.Generic.List[object]]::new()
        SuspiciousHits = [System.Collections.Generic.List[object]]::new()
        UnbackedExec   = [System.Collections.Generic.List[object]]::new()
        Regions        = 0
        ScannedBytes   = 0
        Error          = $null
    }
    $hProc = [Win32Mem]::OpenProcess(
        [Win32Mem]::PROCESS_VM_READ -bor [Win32Mem]::PROCESS_QUERY_INFORMATION, $false, $procPid)
    if ($hProc -eq [IntPtr]::Zero) { $res.Error = "Access denied"; return $res }
    try {
        $si = New-Object Win32Mem+SYSTEM_INFO
        [Win32Mem]::GetSystemInfo([ref]$si)
        $addr  = $si.lpMinimumApplicationAddress
        $max   = $si.lpMaximumApplicationAddress
        $total = 0
        while ($addr.ToInt64() -lt $max.ToInt64() -and $total -lt $maxBytesPerProcess) {
            $mbi     = New-Object Win32Mem+MEMORY_BASIC_INFORMATION
            $mbiSize = [uint32][System.Runtime.InteropServices.Marshal]::SizeOf($mbi)
            $qr      = [Win32Mem]::VirtualQueryEx($hProc, $addr, [ref]$mbi, $mbiSize)
            if ($qr -eq 0) { $addr = [IntPtr]($addr.ToInt64() + 0x1000); continue }
            $res.Regions++
            if ($mbi.State -eq [Win32Mem]::MEM_COMMIT) {
                $protect   = $mbi.Protect
                $type      = $mbi.Type
                $size      = $mbi.RegionSize.ToInt64()
                $guarded   = ($protect -band [Win32Mem]::PAGE_GUARD) -ne 0
                $noaccess  = ($protect -band [Win32Mem]::PAGE_NOACCESS) -ne 0
                $isExec    = ($protect -band 0xF0) -ne 0
                $isPrivate = $type -eq [Win32Mem]::MEM_PRIVATE
                if ($isExec -and $isPrivate -and -not $guarded -and -not $noaccess) {
                    $res.UnbackedExec.Add([PSCustomObject]@{
                        Address    = "0x$($mbi.BaseAddress.ToInt64().ToString('X16'))"
                        SizeKB     = [math]::Round($size / 1KB, 1)
                        Protection = Get-ProtectionName $protect
                    })
                }
                $readable = ($protect -band 0xFE) -ne 0
                if ($readable -and $isPrivate -and -not $guarded -and -not $noaccess -and $size -gt 0) {
                    $rs  = [int][math]::Min($size, $maxReadSize)
                    $buf = New-Object byte[] $rs
                    $br  = 0
                    $ok  = [Win32Mem]::ReadProcessMemory($hProc, $mbi.BaseAddress, $buf, $rs, [ref]$br)
                    if ($ok -and $br -gt 0) {
                        $res.ScannedBytes += $br
                        $total += $br
                        $hits   = Search-MemoryRegion $buf $br
                        $av     = $mbi.BaseAddress.ToInt64()
                        foreach ($h in $hits) {
                            $hitObj = [PSCustomObject]@{
                                String  = $h
                                Address = "0x$($av.ToString('X16'))"
                                Region  = "PRIVATE/$(Get-ProtectionName $protect)"
                                SizeKB  = [math]::Round($br / 1KB, 1)
                            }
                            if (Test-SuspiciousMemString $h) { $res.SuspiciousHits.Add($hitObj) }
                            else                             { $res.StringHits.Add($hitObj) }
                        }
                    }
                }
            }
            $next = $mbi.BaseAddress.ToInt64() + $mbi.RegionSize.ToInt64()
            if ($next -le $addr.ToInt64()) { $next = $addr.ToInt64() + 0x1000 }
            $addr = [IntPtr]$next
        }
    } finally { [Win32Mem]::CloseHandle($hProc) | Out-Null }
    return $res
}

# =====================================================
# PARALLEL PREFETCH SCAN
# =====================================================
function Scan-PrefetchParallel($pfFiles, $cutoff, $scanDaysBack, $exactTermsArg, $globalFPPatternsArg) {
    $pool = [RunspaceFactory]::CreateRunspacePool(1, [Environment]::ProcessorCount)
    $pool.Open()
    $jobs    = [System.Collections.Generic.List[hashtable]]::new()
    $results = [System.Collections.Generic.List[object]]::new()

    $workerScript = {
        param($pf, $cutoff, $scanDaysBack, $exactTerms, $globalFPPatterns)
        function Get-PfTimestamps($path) {
            $times = [System.Collections.Generic.List[DateTime]]::new()
            try {
                $bytes = [System.IO.File]::ReadAllBytes($path)
                if ($bytes.Length -lt 136) { return $times }
                $ver = [System.BitConverter]::ToUInt32($bytes, 0)
                if ($ver -eq 30 -or $ver -eq 31) {
                    for ($i = 0; $i -lt 8; $i++) {
                        $off = 128 + ($i * 8)
                        if ($off + 8 -gt $bytes.Length) { break }
                        $ft = [System.BitConverter]::ToInt64($bytes, $off)
                        if ($ft -gt 0 -and $ft -lt 999999999999999999L) {
                            $times.Add([DateTime]::FromFileTimeUtc($ft).ToLocalTime())
                        }
                    }
                } else {
                    $ft = [System.BitConverter]::ToInt64($bytes, 128)
                    if ($ft -gt 0 -and $ft -lt 999999999999999999L) { $times.Add([DateTime]::FromFileTimeUtc($ft).ToLocalTime()) }
                }
            } catch {}
            return $times
        }
        $base      = [System.IO.Path]::GetFileNameWithoutExtension($pf.Name)
        $exeName   = if ($base -match '^(.+)-[0-9A-F]{8}$') { $Matches[1] } else { $base }
        $ts        = Get-PfTimestamps $pf.FullName
        $lastRunDt = if ($ts.Count -gt 0) { $ts[0] } else { $pf.LastWriteTime }
        if ($scanDaysBack -lt 9999 -and $lastRunDt -lt $cutoff) { return $null }
        $lower = $exeName.ToLower()
        $isFP  = $false
        foreach ($p in $globalFPPatterns) { if ($lower -like "*$($p.ToLower())*") { $isFP = $true; break } }
        $matchedTerm = $null
        if (-not $isFP) {
            foreach ($term in $exactTerms) {
                $t = $term.ToLower()
                if ($lower -eq $t -or ($t.Length -gt 5 -and $lower -like "*$t*")) { $matchedTerm = $term; break }
            }
        }
        return [PSCustomObject]@{
            FileName    = $pf.Name
            Exe         = $exeName
            SizeKB      = [math]::Round($pf.Length / 1KB, 2)
            LastRun     = $lastRunDt.ToString("yyyy-MM-dd HH:mm:ss")
            AllRunTimes = if ($ts.Count -gt 1) { ($ts | ForEach-Object { $_.ToString("yyyy-MM-dd HH:mm:ss") }) -join " | " } else { $lastRunDt.ToString("yyyy-MM-dd HH:mm:ss") }
            RunCount    = $ts.Count
            Match       = $matchedTerm
            Flagged     = ($null -ne $matchedTerm)
        }
    }

    foreach ($pf in $pfFiles) {
        $ps = [PowerShell]::Create()
        $ps.RunspacePool = $pool
        $ps.AddScript($workerScript) | Out-Null
        $ps.AddArgument($pf)                  | Out-Null
        $ps.AddArgument($cutoff)              | Out-Null
        $ps.AddArgument($scanDaysBack)        | Out-Null
        $ps.AddArgument($exactTermsArg)       | Out-Null
        $ps.AddArgument($globalFPPatternsArg) | Out-Null
        $jobs.Add(@{ PS = $ps; Handle = $ps.BeginInvoke() })
    }
    foreach ($job in $jobs) {
        try { $res = $job.PS.EndInvoke($job.Handle); if ($res -and $res[0]) { $results.Add($res[0]) } } catch {}
        $job.PS.Dispose()
    }
    $pool.Close(); $pool.Dispose()
    return $results
}
# =====================================================
# SECTION 1 -- SYSTEM PROTECTION
# =====================================================
function Run-Section1 {
    Write-Header "SECTION 1 -- SYSTEM PROTECTION" "Cyan"
    $hits = 0

    Write-Info "Checking Windows Defender status..."
    try {
        $mpStatus = Get-MpComputerStatus -ErrorAction Stop
        if ($mpStatus.AntivirusEnabled) { Write-OK "Defender antivirus: Enabled" }
        else {
            Write-Fail "Defender antivirus: DISABLED"
            Add-Finding "SystemProtection" "DefenderDisabled" "Antivirus disabled" "" "Defender Status" $null 50
            Add-Timeline "Defender antivirus disabled"
            $hits++
        }
        if ($mpStatus.RealTimeProtectionEnabled) { Write-OK "Real-time protection: Enabled" }
        else {
            Write-Fail "Real-time protection: DISABLED"
            Add-Finding "SystemProtection" "RTPDisabled" "Real-time protection disabled" "" "Defender Status" $null 40
            $hits++
        }
        if ($mpStatus.IsTamperProtected) { Write-OK "Tamper protection: Enabled" }
        else {
            Write-Warn "Tamper protection: Disabled"
            Add-Finding "SystemProtection" "TamperDisabled" "Tamper protection disabled" "" "Defender Status" $null 20
            $hits++
        }
    } catch { Write-Warn "Could not query Defender status" }

    Write-Info "Checking Defender exclusions..."
    try {
        $prefs = Get-MpPreference -ErrorAction Stop
        $allExclusions = @(
            ($prefs.ExclusionPath      | ForEach-Object { @{ Type="Path";      Value=$_ } }),
            ($prefs.ExclusionProcess   | ForEach-Object { @{ Type="Process";   Value=$_ } }),
            ($prefs.ExclusionExtension | ForEach-Object { @{ Type="Extension"; Value=$_ } })
        ) | ForEach-Object { $_ } | Where-Object { $_.Value }

        if ($allExclusions.Count -eq 0) { Write-OK "No Defender exclusions found" }
        else {
            foreach ($excl in $allExclusions) {
                $isSusp = Test-CheatMatch $excl.Value.ToLower()
                if ($isSusp) {
                    Write-Hit "Defender exclusion HIT [$($excl.Type)]: $($excl.Value) -- matches '$isSusp'"
                    Add-Finding "SystemProtection" "SuspExclusion" "$($excl.Type): $($excl.Value)" $isSusp "Defender Exclusions" $null 60
                    Add-Timeline "Suspicious Defender exclusion: $($excl.Value)"
                    $hits++
                } else {
                    Write-Warn "Defender exclusion [$($excl.Type)]: $($excl.Value)"
                    Add-Finding "SystemProtection" "Exclusion" "$($excl.Type): $($excl.Value)" "" "Defender Exclusions" $null 15
                }
            }
        }
    } catch { Write-Warn "Could not query Defender exclusions" }

    Write-Info "Checking Memory Integrity (HVCI)..."
try {
    $dg = Get-CimInstance -ClassName Win32_DeviceGuard -Namespace root\Microsoft\Windows\DeviceGuard -ErrorAction Stop
    if ($dg -and ($dg.SecurityServicesRunning -contains 2)) {
        Write-OK "Memory Integrity: Active and enforced"
    } else {
        Write-Fail "Memory Integrity: NOT actively enforced at runtime"
        Add-Finding "SystemProtection" "HVCIDisabled" "Memory Integrity not enforced" "" "Memory Integrity" $null 15
        $hits++
    }
} catch { Write-Warn "Could not query Memory Integrity via Win32_DeviceGuard" }

    Write-Info "Checking vulnerable driver blocklist..."
    try {
        $blKey = "HKLM:\SYSTEM\CurrentControlSet\Control\CI\Config"
        if (Test-Path $blKey) {
            $bl = (Get-ItemProperty $blKey -ErrorAction SilentlyContinue).VulnerableDriverBlocklistEnable
            if ($bl -eq 1) { Write-OK "Vulnerable driver blocklist: Enabled" }
            else {
                Write-Warn "Vulnerable driver blocklist: Disabled"
                Add-Finding "SystemProtection" "BlocklistDisabled" "Driver blocklist off" "" "Driver Blocklist" $null 20
                $hits++
            }
        }
    } catch {}

    Write-Info "Checking AMSI providers..."
    try {
        $amsiKey = "HKLM:\SOFTWARE\Microsoft\AMSI\Providers"
        if (Test-Path $amsiKey) {
            $providers = Get-ChildItem $amsiKey -ErrorAction SilentlyContinue
            if ($providers.Count -gt 0) { Write-OK "AMSI providers registered: $($providers.Count)" }
            else {
                Write-Fail "No AMSI providers registered -- possible AMSI bypass"
                Add-Finding "SystemProtection" "AMSIStripped" "No AMSI providers" "" "AMSI Integrity" $null 50
                $hits++
            }
        } else { Write-Info "AMSI providers key not found" }
    } catch {}

    Write-Info "Checking WMI event subscriptions..."
    try {
        $consumers = Get-WMIObject -Namespace root\subscription -Class __EventConsumer -ErrorAction Stop
        $wmiHits = 0
        foreach ($c in $consumers) {
            $name = $c.Name
            $isFP = $false
            foreach ($kw in $knownWmiConsumers) { if ($name -like "*$kw*") { $isFP = $true; break } }
            if (-not $isFP) {
                Write-Hit "Suspicious WMI consumer: $name"
                Add-Finding "Persistence" "WMIConsumer" $name "" $null "Persistence" 40
                Add-Timeline "WMI persistence consumer: $name"
                $wmiHits++; $hits++
            } else { Write-Info "WMI consumer (known): $name" }
        }
        if ($wmiHits -eq 0) { Write-OK "No suspicious WMI subscriptions" }
    } catch { Write-Info "WMI subscription check skipped" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 2 -- NETWORK & DNS
# =====================================================
function Run-Section2 {
    Write-Header "SECTION 2 -- NETWORK & DNS" "Cyan"
    $hits = 0

    Write-Info "Checking active network connections..."
    try {
        $conns = Get-NetTCPConnection -State Established,TimeWait -ErrorAction Stop
        $connHits = 0
        foreach ($conn in $conns) {
            $remote = $conn.RemoteAddress
            $port   = $conn.RemotePort
            foreach ($domain in $suspiciousDomains) {
                if ($remote -like "*$domain*") {
                    Write-Hit "Active connection to suspicious domain: $remote : $port"
                    Add-Finding "NetworkDNS" "SuspConnection" "$remote : $port" $domain $null "Network Activity" 50
                    $connHits++; $hits++
                }
            }
            if ($suspiciousPorts -contains $port) {
                Write-Warn "Connection on suspicious port: $remote : $port"
                Add-Finding "NetworkDNS" "SuspPort" "$remote : $port" $port $null "Network Activity" 20
                $connHits++; $hits++
            }
        }
        if ($connHits -eq 0) { Write-OK "No suspicious active connections" }
    } catch { Write-Warn "Could not query TCP connections" }

    Write-Info "Checking DNS cache..."
    try {
        $dnsCache = Get-DnsClientCache -ErrorAction Stop
        $dnsHits  = 0
        foreach ($entry in $dnsCache) {
            $name = $entry.Entry.ToLower()
            foreach ($domain in $suspiciousDomains) {
                if ($name -like "*$($domain.ToLower())*") {
                    Write-Hit "DNS cache HIT: $name"
                    Add-Finding "NetworkDNS" "DNSCache" $name $domain $null "Network Activity" 40
                    Add-Timeline "DNS cache: $name"
                    $dnsHits++; $hits++
                }
            }
        }
        if ($dnsHits -eq 0) { Write-OK "No suspicious DNS cache entries" }
    } catch { Write-Info "DNS cache check skipped" }

    Write-Info "Checking hosts file for redirects..."
    $hostsPath = "C:\Windows\System32\drivers\etc\hosts"
    if (Test-Path $hostsPath) {
        $hostsHits  = 0
        $hostsLines = Get-Content $hostsPath -ErrorAction SilentlyContinue |
            Where-Object { $_ -notmatch "^\s*#" -and $_.Trim() -ne "" }
        foreach ($line in $hostsLines) {
            foreach ($domain in $suspiciousDomains) {
                if ($line -like "*$domain*") {
                    Write-Warn "Hosts file entry for suspicious domain: $line"
                    Add-Finding "NetworkDNS" "HostsEntry" $line $domain $null "Network Activity" 25
                    $hostsHits++; $hits++
                }
            }
        }
        if ($hostsHits -eq 0) { Write-OK "Hosts file: No suspicious entries" }
    }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 3 -- FILESYSTEM EXECUTION ARTIFACTS
# =====================================================
function Run-Section3 {
    Write-Header "SECTION 3 -- FILESYSTEM EXECUTION ARTIFACTS" "Cyan"
    $hits = 0

    Write-Info "Scanning MUICache..."
    $before = $hits
    try {
        $muiPath = "HKCU:\SOFTWARE\Classes\Local Settings\Software\Microsoft\Windows\Shell\MuiCache"
        $mui     = Get-ItemProperty $muiPath -ErrorAction Stop
        $mui.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
            $entry = $_.Name
            if (-not (Is-MUIFalsePositive $entry)) {
                $match = Test-CheatMatch $entry.ToLower()
                if ($match) {
                    Write-Hit "MUICache HIT: $entry -- matches '$match'"
                    Add-Finding "FilesystemExecution" "MUICache" $entry $match $null "Filesystem Execution" 30
                    Add-Timeline "MUICache hit: $entry"
                    $hits++
                }
            }
        }
        if ($hits -eq $before) { Write-OK "MUICache: No suspicious entries" }
    } catch { Write-Warn "MUICache scan failed" }

    Write-Info "Scanning UserAssist..."
    $before = $hits
    try {
        $uaBase = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\UserAssist"
        foreach ($k in @(Get-ChildItem $uaBase -ErrorAction SilentlyContinue)) {
            $countPath = "$($k.PSPath)\Count"
            if (-not (Test-Path $countPath)) { continue }
            $props = Get-ItemProperty $countPath -ErrorAction SilentlyContinue
            if (-not $props) { continue }
            $props.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
                $decoded = UnROT13 $_.Name
                if (-not (Is-UAFalsePositive $decoded)) {
                    $match = Test-CheatMatch $decoded.ToLower()
                    if ($match) {
                        Write-Hit "UserAssist HIT: $decoded -- matches '$match'"
                        Add-Finding "FilesystemExecution" "UserAssist" $decoded $match $null "Filesystem Execution" 30
                        Add-Timeline "UserAssist hit: $decoded"
                        $hits++
                    }
                }
            }
        }
        if ($hits -eq $before) { Write-OK "UserAssist: No suspicious entries" }
    } catch { Write-Warn "UserAssist scan failed" }

    Write-Info "Scanning Shimcache..."
    $before = $hits
    try {
        $shimPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\AppCompatCache"
        $shimRaw  = (Get-ItemProperty $shimPath -ErrorAction Stop).AppCompatCache
        if ($shimRaw -and $shimRaw.Length -gt 16) {
            $ustr = [System.Text.Encoding]::Unicode.GetString($shimRaw)
            $seen = [System.Collections.Generic.HashSet[string]]::new()
            [regex]::Matches($ustr, '[A-Za-z]:\\[^\x00-\x1F"<>|]{4,200}') | ForEach-Object {
                $val = $_.Value.Trim() -replace "[^\x20-\x7E]",""
                if ($val.Length -ge 5 -and $seen.Add($val) -and -not $script:shimFPRegex.IsMatch($val)) {
                    $match = Test-CheatMatch $val.ToLower()
                    if ($match) {
                        Write-Hit "Shimcache HIT: $val -- matches '$match'"
                        Add-Finding "FilesystemExecution" "Shimcache" $val $match $null "Filesystem Execution" 25
                        Add-Timeline "Shimcache hit: $val"
                        $hits++
                    }
                }
            }
        }
        if ($hits -eq $before) { Write-OK "Shimcache: No suspicious entries" }
    } catch { Write-Warn "Shimcache scan failed" }

    Write-Info "Scanning BAM (Background Activity Monitor)..."
    $before = $hits
    try {
        $bamBase = "HKLM:\SYSTEM\CurrentControlSet\Services\bam\State\UserSettings"
        if (Test-Path $bamBase) {
            $tz   = Get-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Control\TimeZoneInformation" -ErrorAction SilentlyContinue
            $bias = if ($tz -and $null -ne $tz.ActiveTimeBias) { [int64]$tz.ActiveTimeBias } else { 0L }
            foreach ($bk in @(Get-ChildItem $bamBase -ErrorAction SilentlyContinue | Where-Object { $_.PSChildName -ne "S-1-5-18" })) {
                $regKey = Get-Item $bk.PSPath -ErrorAction SilentlyContinue
                if (-not $regKey) { continue }
                $propNames = try { $regKey.GetValueNames() } catch { @() }
                foreach ($prop in $propNames) {
                    if ($prop -in @("SequenceNumber","Version","")) { continue }
                    try {
                        $raw = $regKey.GetValue($prop)
                        if (-not $raw -or $raw -isnot [byte[]] -or $raw.Length -lt 8) { continue }
                        $ft = [System.BitConverter]::ToInt64($raw[0..7], 0)
                        if ($ft -le 0 -or $ft -gt 999999999999999999) { continue }
                        $lr = [DateTime]::FromFileTimeUtc($ft).AddMinutes(-$bias)
                        if ($script:ScanDaysBack -lt 9999 -and $lr -lt $script:ScanCutoff) { continue }
                        $lrStr = $lr.ToString("yyyy-MM-dd HH:mm:ss")

                        $bamEntry = [PSCustomObject]@{ Path = $prop; LastRun = $lrStr; SID = $bk.PSChildName; Flagged = $false; Match = "" }
                        $bamViewerData.Add($bamEntry)

                        if (-not (Is-BAMFalsePositive $prop)) {
                            $match = Test-CheatMatch $prop.ToLower()
                            if ($match) {
                                Write-Hit "BAM HIT: $prop (last run: $lrStr) -- matches '$match'"
                                Add-Finding "FilesystemExecution" "BAM" $prop $match $null "Filesystem Execution" 35
                                Add-Timeline "BAM hit: $prop"
                                $bamEntry.Flagged = $true
                                $bamEntry.Match   = $match
                                $hits++
                            }
                        }
                    } catch { continue }
                }
            }
        }
        if ($hits -eq $before) { Write-OK "BAM: No suspicious entries" }
    } catch { Write-Warn "BAM scan failed" }

    Write-Info "Scanning Prefetch (parallel)..."
    $before = $hits
    $pfPath = "C:\Windows\Prefetch"
    if (Test-Path $pfPath) {
        $pfFiles = @(Get-ChildItem $pfPath -Filter "*.pf" -File -Force -ErrorAction SilentlyContinue)
        Write-Info "Prefetch files found: $($pfFiles.Count)"
        $pfResults = Scan-PrefetchParallel $pfFiles $script:ScanCutoff $script:ScanDaysBack $exactTerms $globalFPPatterns
        foreach ($pf in $pfResults) {
            $prefetchViewerData.Add($pf)
            if ($pf.Flagged) {
                Write-Hit "Prefetch HIT: $($pf.Exe) (last run: $($pf.LastRun)) -- matches '$($pf.Match)'"
                Add-Finding "FilesystemExecution" "Prefetch" $pf.Exe $pf.Match $null "Filesystem Execution" 35
                Add-Timeline "Prefetch hit: $($pf.Exe)"
                $hits++
            }
        }
        if ($hits -eq $before) { Write-OK "Prefetch: No suspicious entries" }
    } else { Write-Info "Prefetch directory not found" }

    Write-Info "Checking for renamed cheat executables via PE header strings..."
    $before = $hits
    $searchPaths = @(
        "$env:TEMP","$env:LOCALAPPDATA\Temp","$env:APPDATA","$env:LOCALAPPDATA",
        "$env:USERPROFILE\Downloads","$env:USERPROFILE\Desktop"
    )
    foreach ($sp in $searchPaths) {
        if (-not (Test-Path $sp)) { continue }
        $exes = Get-ChildItem $sp -Filter "*.exe" -File -Force -ErrorAction SilentlyContinue |
            Where-Object { $script:ScanDaysBack -ge 9999 -or $_.LastWriteTime -ge $script:ScanCutoff }
        foreach ($exe in $exes) {
            try {
                $bytes = [System.IO.File]::ReadAllBytes($exe.FullName)
                if ($bytes.Length -lt 64) { continue }
                $upTo = [math]::Min($bytes.Length - 1, 65535)
                $str  = [System.Text.Encoding]::ASCII.GetString($bytes[0..$upTo])
                if (Is-GlobalFP $exe.FullName) { continue }
                foreach ($term in $exactTerms) {
                    if ($str.ToLower() -like "*$($term.ToLower())*") {
                        Write-Hit "Renamed cheat PE: $($exe.FullName) contains string '$term'"
                        Add-Finding "FilesystemExecution" "RenamedPE" $exe.FullName $term $null "Filesystem Execution" 50
                        Add-Timeline "Renamed cheat PE: $($exe.FullName)"
                        $hits++
                        break
                    }
                }
            } catch { continue }
        }
    }
    if ($hits -eq $before) { Write-OK "PE header scan: No renamed cheats found" }

    Write-Info "Checking for generic-named executables in suspicious locations..."
    $before = $hits
    $suspLocations = @("$env:TEMP","$env:LOCALAPPDATA\Temp","$env:APPDATA")
    $genericNames  = @("update","updater","service","helper","loader","launcher","runner","install","setup","patch")
    foreach ($loc in $suspLocations) {
        if (-not (Test-Path $loc)) { continue }
        $exes = Get-ChildItem $loc -Filter "*.exe" -File -Force -ErrorAction SilentlyContinue |
            Where-Object { $script:ScanDaysBack -ge 9999 -or $_.LastWriteTime -ge $script:ScanCutoff }
        foreach ($exe in $exes) {
            $baseName = [System.IO.Path]::GetFileNameWithoutExtension($exe.Name).ToLower()
            if ($genericNames -contains $baseName -and -not (Is-GlobalFP $exe.FullName)) {
                $entropy = Get-FileEntropy $exe.FullName
                if ($entropy -ge $entropyWarn) {
                    Write-Warn "Generic exe in temp with high entropy ($entropy): $($exe.FullName)"
                    Add-Finding "FilesystemExecution" "GenericExe" $exe.FullName "entropy:$entropy" $null "Filesystem Execution" 25
                    $hits++
                }
            }
        }
    }
    if ($hits -eq $before) { Write-OK "Generic-name scan: No suspicious executables" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 4 -- PERSISTENCE
# =====================================================
function Run-Section4 {
    Write-Header "SECTION 4 -- PERSISTENCE" "Cyan"
    $hits = 0

    $runKeys = @(
        "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run",
        "HKCU:\Software\Microsoft\Windows\CurrentVersion\RunOnce",
        "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run",
        "HKLM:\Software\Microsoft\Windows\CurrentVersion\RunOnce",
        "HKLM:\Software\WOW6432Node\Microsoft\Windows\CurrentVersion\Run"
    )
    Write-Info "Scanning registry run keys..."
    $runHits = 0
    foreach ($key in $runKeys) {
        if (-not (Test-Path $key)) { continue }
        $props = Get-ItemProperty $key -ErrorAction SilentlyContinue
        if (-not $props) { continue }
        $props.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
            $val = $_.Value
            if ($val -and -not (Is-GlobalFP $val)) {
                $match = Test-CheatMatch $val.ToLower()
                if ($match) {
                    Write-Hit "Run key HIT: [$($_.Name)] = $val -- matches '$match'"
                    Add-Finding "Persistence" "RunKey" $_.Name $val $null "Persistence" 45
                    Add-Timeline "Run key hit: $val"
                    $runHits++
                }
            }
        }
    }
    $hits += $runHits
    if ($runHits -eq 0) { Write-OK "Run keys: No suspicious entries" }

    Write-Info "Checking startup folders..."
    $startupHits = 0
    $startupPaths = @(
        "$env:APPDATA\Microsoft\Windows\Start Menu\Programs\Startup",
        "C:\ProgramData\Microsoft\Windows\Start Menu\Programs\Startup"
    )
    foreach ($sp in $startupPaths) {
        if (-not (Test-Path $sp)) { continue }
        $items = Get-ChildItem $sp -File -Force -ErrorAction SilentlyContinue
        foreach ($item in $items) {
            if (Is-GlobalFP $item.FullName) { continue }
            $match = Test-CheatMatch $item.Name.ToLower()
            if ($match) {
                Write-Hit "Startup folder HIT: $($item.FullName) -- matches '$match'"
                Add-Finding "Persistence" "StartupFolder" $item.FullName $match $null "Persistence" 40
                Add-Timeline "Startup folder hit: $($item.FullName)"
                $startupHits++
            } else {
                Write-Warn "Startup folder item: $($item.FullName)"
                Add-Finding "Persistence" "StartupItem" $item.FullName "" $null "Persistence" 5
            }
        }
    }
    $hits += $startupHits
    if ($startupHits -eq 0) { Write-OK "Startup folders: No cheat matches" }

    Write-Info "Scanning scheduled tasks..."
    $taskHits = 0
    try {
        $tasks = Get-ScheduledTask -ErrorAction Stop | Where-Object { $_.State -ne "Disabled" }
        foreach ($task in $tasks) {
            $taskName = $task.TaskName
            $actions  = $task.Actions | ForEach-Object { "$($_.Execute) $($_.Arguments)" }
            foreach ($action in $actions) {
                if (-not $action -or (Is-GlobalFP $action)) { continue }
                $match = Test-CheatMatch $action.ToLower()
                if ($match) {
                    Write-Hit "Scheduled task HIT: '$taskName' -> $action -- matches '$match'"
                    Add-Finding "Persistence" "ScheduledTask" $taskName $action $null "Persistence" 40
                    Add-Timeline "Scheduled task hit: $taskName"
                    $taskHits++
                }
            }
        }
    } catch { Write-Warn "Scheduled task scan failed" }
    $hits += $taskHits
    if ($taskHits -eq 0) { Write-OK "Scheduled tasks: No suspicious entries" }

    Write-Info "Checking for hidden processes (WMI vs Get-Process delta)..."
    $hiddenHits = 0
    try {
        $wmiProcs  = @(Get-WmiObject Win32_Process -ErrorAction Stop | Select-Object -ExpandProperty ProcessId)
        $psProcs   = @(Get-Process -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Id)
        $hiddenIds = $wmiProcs | Where-Object { $psProcs -notcontains $_ }
        foreach ($hid in $hiddenIds) {
            $wmiProc = Get-WmiObject Win32_Process -Filter "ProcessId=$hid" -ErrorAction SilentlyContinue
            if ($wmiProc) {
                Write-Warn "Potentially hidden process: $($wmiProc.Name) (PID $hid)"
                Add-Finding "Persistence" "HiddenProcess" $wmiProc.Name "PID:$hid" $null "Persistence" 35
                $hiddenHits++
            }
        }
    } catch { Write-Info "Hidden process check skipped" }
    $hits += $hiddenHits
    if ($hiddenHits -eq 0) { Write-OK "No hidden processes detected" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 5 -- REGISTRY EXECUTION ARTIFACTS
# =====================================================
function Run-Section5 {
    Write-Header "SECTION 5 -- REGISTRY EXECUTION ARTIFACTS" "Cyan"
    $hits = 0

    Write-Info "Scanning AppCompatFlags..."
    $acfKeys = @(
        "HKCU:\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Compatibility Assistant\Store",
        "HKLM:\Software\Microsoft\Windows NT\CurrentVersion\AppCompatFlags\Compatibility Assistant\Store"
    )
    foreach ($key in $acfKeys) {
        if (-not (Test-Path $key)) { continue }
        $props = Get-ItemProperty $key -ErrorAction SilentlyContinue
        if (-not $props) { continue }
        $props.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
            $name = $_.Name
            if (-not (Is-GlobalFP $name)) {
                $match = Test-CheatMatch $name.ToLower()
                if ($match) {
                    Write-Hit "AppCompatFlags HIT: $name -- matches '$match'"
                    Add-Finding "RegistryExecution" "AppCompatFlags" $name $match $null "Registry Execution" 30
                    $hits++
                }
            }
        }
    }

    Write-Info "Scanning Explorer TypedPaths..."
    $tpKey = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\TypedPaths"
    if (Test-Path $tpKey) {
        $props = Get-ItemProperty $tpKey -ErrorAction SilentlyContinue
        if ($props) {
            $props.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
                $val = $_.Value
                if ($val -and -not (Is-GlobalFP $val)) {
                    $match = Test-CheatMatch $val.ToLower()
                    if ($match) {
                        Write-Hit "TypedPaths HIT: $val -- matches '$match'"
                        Add-Finding "RegistryExecution" "TypedPaths" $val $match $null "Registry Execution" 25
                        $hits++
                    }
                }
            }
        }
    }

    Write-Info "Scanning RecentDocs registry..."
    $rdKey = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\RecentDocs"
    if (Test-Path $rdKey) {
        Get-ChildItem $rdKey -ErrorAction SilentlyContinue | ForEach-Object {
            $props = Get-ItemProperty $_.PSPath -ErrorAction SilentlyContinue
            if (-not $props) { return }
            $props.PSObject.Properties | Where-Object { $_.Name -notlike "PS*" } | ForEach-Object {
                $raw = $_.Value
                if ($raw -is [byte[]]) {
                    $str = ([System.Text.Encoding]::Unicode.GetString($raw)) -replace "[^\x20-\x7E]",""
                    if ($str -and -not (Is-GlobalFP $str)) {
                        $match = Test-CheatMatch $str.ToLower()
                        if ($match) {
                            Write-Hit "RecentDocs HIT: $str -- matches '$match'"
                            Add-Finding "RegistryExecution" "RecentDocs" $str $match $null "Registry Execution" 20
                            $hits++
                        }
                    }
                }
            }
        }
    }

    if ($hits -eq 0) { Write-OK "Registry execution artifacts: No suspicious entries" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 6 -- POWERSHELL HISTORY & ENTROPY
# =====================================================
function Run-Section6 {
    Write-Header "SECTION 6 -- POWERSHELL HISTORY & ENTROPY" "Cyan"
    $hits = 0

    Write-Info "Scanning PowerShell history files..."
    $psHits = 0
    $historyPaths = [System.Collections.Generic.List[string]]::new()
    foreach ($profile in $allUserProfiles) {
        $hp = "$profile\AppData\Roaming\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt"
        if (Test-Path $hp) { $historyPaths.Add($hp) }
    }
    foreach ($hPath in $historyPaths) {
        try {
            $lines = Get-Content $hPath -ErrorAction Stop | Where-Object { $_.Trim() -ne "" }
            foreach ($line in $lines) {
                $lower = $line.ToLower()
                $isFP  = $false
                foreach ($fp in $psFPPatterns) { if ($lower -like "*$fp*") { $isFP = $true; break } }
                if ($isFP) { continue }
                $matchedRemote = $false
                foreach ($pattern in $remoteExecPatterns) {
                    if ($lower -like "*$($pattern.Pattern)*") {
                        Write-Warn "PS History [$($pattern.Label)]: $line"
                        Add-Finding "RegistryExecution" "PSHistory" $line $pattern.Label $null "PowerShell History" 30
                        $psHits++
                        $matchedRemote = $true
                        break
                    }
                }
                if ($matchedRemote) { continue }
                $match = Test-CheatMatch $lower
                if ($match) {
                    Write-Hit "PS History cheat match: $line -- matches '$match'"
                    Add-Finding "RegistryExecution" "PSHistoryCheat" $line $match $null "PowerShell History" 40
                    $psHits++
                }
            }
        } catch { continue }
    }
    $hits += $psHits
    if ($psHits -eq 0) { Write-OK "PowerShell history: No suspicious commands" }

    Write-Info "Running entropy scan on suspicious locations..."
    $entHits = 0
    $entropyScanPaths = @(
        "$env:TEMP","$env:LOCALAPPDATA\Temp","$env:APPDATA",
        "$env:USERPROFILE\Downloads","$env:USERPROFILE\Desktop"
    )
    foreach ($sp in $entropyScanPaths) {
        if (-not (Test-Path $sp)) { continue }
        $exes = Get-ChildItem $sp -Filter "*.exe" -File -Force -ErrorAction SilentlyContinue |
            Where-Object { $script:ScanDaysBack -ge 9999 -or $_.LastWriteTime -ge $script:ScanCutoff }
        foreach ($exe in $exes) {
            if (Is-GlobalFP $exe.FullName) { continue }
            $entropy = Get-FileEntropy $exe.FullName
            if ($entropy -ge $entropyHigh) {
                Write-Hit "High entropy executable ($entropy): $($exe.FullName)"
                Add-Finding "FilesystemExecution" "HighEntropy" $exe.FullName "entropy:$entropy" $null "Entropy Scan" 30
                $entropyResults.Add([PSCustomObject]@{ Path=$exe.FullName; Entropy=$entropy; Flag="HIGH" })
                $entHits++
            } elseif ($entropy -ge $entropyWarn) {
                Write-Warn "Elevated entropy executable ($entropy): $($exe.FullName)"
                $entropyResults.Add([PSCustomObject]@{ Path=$exe.FullName; Entropy=$entropy; Flag="WARN" })
            }
        }
    }
    $hits += $entHits
    if ($entHits -eq 0) { Write-OK "Entropy scan: No high-entropy executables found" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# SECTION 7 -- RECENT ACTIVITY
# =====================================================
function Run-Section7 {
    Write-Header "SECTION 7 -- RECENT ACTIVITY" "Cyan"
    $hits = 0

    Write-Info "Scanning recent files..."
    $recentHits = 0
    $recentPath = "$env:APPDATA\Microsoft\Windows\Recent"
    if (Test-Path $recentPath) {
        $recent = Get-ChildItem $recentPath -File -Force -ErrorAction SilentlyContinue |
            Where-Object { $script:ScanDaysBack -ge 9999 -or $_.LastWriteTime -ge $script:ScanCutoff }
        foreach ($item in $recent) {
            $match = Test-CheatMatch $item.Name.ToLower()
            if ($match -and -not (Is-GlobalFP $item.FullName)) {
                Write-Hit "Recent file HIT: $($item.Name) -- matches '$match'"
                Add-Finding "RecentActivity" "RecentFile" $item.Name $match $null "Filesystem Execution" 20
                $recentHits++
            }
        }
    }
    $hits += $recentHits
    if ($recentHits -eq 0) { Write-OK "Recent files: No suspicious entries" }

    Write-Info "Scanning Event 4688 (process creation)..."
    $evtHits = 0
    try {
        $events4688 = Get-WinEvent -FilterHashtable @{ LogName="Security"; Id=4688; StartTime=$script:ScanCutoff } -MaxEvents 1000 -ErrorAction Stop
        foreach ($ev in $events4688) {
            try {
                $procName = $ev.Properties[5].Value
                $procPath = $ev.Properties[6].Value
                $checkStr = "$procName $procPath".ToLower()
                if (Is-GlobalFP $checkStr) { continue }
                $match = Test-CheatMatch $checkStr
                if ($match) {
                    $timeStr = $ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss")
                    Write-Hit "Event 4688 HIT: $procName at $timeStr -- matches '$match'"
                    Add-Finding "RecentActivity" "ProcessCreation4688" "$procName ($timeStr)" $match $null "Event Log Evidence" 35
                    Add-Timeline "4688: $procName matches '$match' at $timeStr"
                    $evtHits++
                }
            } catch { continue }
        }
    } catch { Write-Info "Event 4688 scan skipped (audit policy or permissions)" }
    $hits += $evtHits
    if ($evtHits -eq 0) { Write-OK "Event 4688: No suspicious process creation events" }

    Write-Info "Checking for Security log clear events (1102)..."
    $clearHits = 0
    try {
        $logClears = Get-WinEvent -FilterHashtable @{ LogName="Security"; Id=1102 } -MaxEvents 20 -ErrorAction Stop |
            Where-Object { $script:ScanDaysBack -ge 9999 -or $_.TimeCreated -ge $script:ScanCutoff }
        foreach ($ev in $logClears) {
            $clearedBy = try { $ev.Properties[1].Value } catch { "Unknown" }
            $msg = "Security log CLEARED at $($ev.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss')) by $clearedBy"
            Write-Critical $msg
            Add-Finding "RecentActivity" "LogClear" $msg "Event 1102" $null "Event Log Evidence" 50
            Add-Timeline "CRITICAL: $msg"
            $kernelFindings.Add([PSCustomObject]@{
                Type = "SecurityLogCleared"; Time = $ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss")
                File = ""; Note = "Security audit log wiped -- possible evasion"
            })
            DeductCheat "Event Log Evidence" 40
            $clearHits++
        }
    } catch { Write-Info "Event 1102 check skipped (insufficient permissions or log unavailable)" }
    $hits += $clearHits
    if ($clearHits -eq 0) { Write-OK "No Security log clear events in time range" }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# ROBLOX FOLDER INTEGRITY
# =====================================================
function Run-RobloxFolderCheck {
    Write-Header "ROBLOX FOLDER INTEGRITY" "Cyan"
    $hits = 0

    $robloxInstalls = [System.Collections.Generic.List[string]]::new()
    foreach ($base in $officialRobloxPaths) {
        if (Test-Path $base) {
            Get-ChildItem $base -Directory -ErrorAction SilentlyContinue |
                Where-Object { $_.Name -match "^version-" } |
                ForEach-Object { $robloxInstalls.Add($_.FullName) }
        }
    }
    if ($robloxInstalls.Count -eq 0) {
        Write-Info "No Roblox installation found"
        Write-SectionResult 0
        return 0
    }

    foreach ($install in $robloxInstalls) {
        Write-Info "Scanning: $install"
        $files = @(Get-ChildItem $install -File -Recurse -Force -ErrorAction SilentlyContinue)
        $total = [math]::Max($files.Count, 1)
        $done  = 0
        foreach ($file in $files) {
            $done++
            if ($done % 50 -eq 0) {
                Write-ProgressBar "Roblox folder" ([math]::Round($done / $total * 100))
            }
            $fname = $file.Name.ToLower()
            $fpath = $file.FullName

            if ($robloxFolderFPFiles -contains $fname) { continue }

            $match = Test-CheatMatch $fname
            if ($match) {
                Write-Host ""
                Write-Hit "Roblox folder HIT: $fpath -- matches '$match'"
                Add-Finding "RobloxFolder" "CheatFile" $fpath $match $null "Roblox Folder" 50
                Add-Timeline "Cheat in Roblox folder: $fpath"
                $robloxFolderResults.Add([PSCustomObject]@{ Path=$fpath; Issue="CheatMatch"; Match=$match; Signed=$false })
                $hits++
                continue
            }

            if ($fname.EndsWith(".dll") -and -not (Is-SignedByRoblox $fpath)) {
                Write-Warn "Unsigned DLL in Roblox folder: $fpath"
                Add-Finding "RobloxFolder" "UnsignedDLL" $fpath "" $null "Roblox Folder" 20
                $robloxFolderResults.Add([PSCustomObject]@{ Path=$fpath; Issue="UnsignedDLL"; Match=""; Signed=$false })
            }
        }
        Write-Host ""
    }

    if ($hits -eq 0) { Write-OK "Roblox folder: No cheat files detected" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# MEMORY SCAN ORCHESTRATOR
# =====================================================
function Run-MemoryScan {
    Write-Header "ROBLOX PROCESS MEMORY SCAN" "Cyan"
    $hits = 0

    $robloxProcs = @(Get-Process -ErrorAction SilentlyContinue |
        Where-Object { $robloxProcessNames -contains $_.ProcessName })

    if ($robloxProcs.Count -eq 0) {
        Write-Warn "No Roblox process found -- run this scan with Roblox open for memory results"
        Write-SectionResult 0
        return 0
    }

    foreach ($proc in $robloxProcs) {
        Write-Info "[1/3] Scanning memory strings: $($proc.ProcessName) (PID $($proc.Id))..."
        $ppath = try { $proc.MainModule.FileName } catch { "" }
        $memResult = Scan-RobloxProcessMemory $proc.Id $proc.ProcessName $ppath

        if ($memResult.Error) {
            Write-Warn "Memory scan error: $($memResult.Error)"
        } else {
            Write-Info "Regions scanned: $($memResult.Regions) | Bytes: $([math]::Round($memResult.ScannedBytes/1MB,1)) MB"
            foreach ($h in $memResult.StringHits) {
                Write-Hit "Memory HIT: '$($h.String)' @ $($h.Address) [$($h.Region)]"
                $memoryFindings.Add($h)
                Add-Finding "ProcessMemory" "MemString" $h.String $h.Address $null "Process Memory" 40
                Add-Timeline "Memory: '$($h.String)' in $($proc.ProcessName)"
                $hits++
            }
            foreach ($s in $memResult.SuspiciousHits) {
                Write-SuspHit "Memory SUSP: '$($s.String)' @ $($s.Address) [$($s.Region)] (Roblox may use this legitimately)"
                $suspiciousMemFindings.Add($s)
                Add-Finding "ProcessMemory" "MemStringSusp" $s.String $s.Address $null "Process Memory" 5
            }
            if ($memResult.StringHits.Count -eq 0) { Write-OK "$($proc.ProcessName) PID $($proc.Id) -- string scan clean" }
            foreach ($ub in ($memResult.UnbackedExec | Where-Object { $_.SizeKB -gt 256 })) {
                Write-Warn "Large PRIVATE exec region: $($ub.Address) [$($ub.Protection)] $($ub.SizeKB) KB"
            }
        }

        Write-Info "[2/3] Thread start address scan: $($proc.ProcessName) (PID $($proc.Id))..."
        $threads = Get-SuspiciousThreads $proc.Id
        foreach ($t in $threads) {
            Write-Critical "Suspicious thread: TID $($t.ThreadID) starts in PRIVATE exec @ $($t.StartAddr) [$($t.Protection)]"
            $threadFindings.Add([PSCustomObject]@{ PID=$proc.Id; Name=$proc.ProcessName; ThreadID=$t.ThreadID; StartAddr=$t.StartAddr; Protection=$t.Protection; RegionKB=$t.RegionKB })
            Add-Finding "ProcessMemory" "SuspThread" "TID:$($t.ThreadID)" $t.StartAddr $null "Process Memory" 50
            Add-Timeline "CRITICAL: Shellcode thread TID $($t.ThreadID) in $($proc.ProcessName)"
            $hits++
        }
        if ($threads.Count -eq 0) { Write-OK "$($proc.ProcessName) PID $($proc.Id) -- thread scan clean" }

        Write-Info "[3/3] Process hollowing check: $($proc.ProcessName) (PID $($proc.Id))..."
        $hollow = Test-ProcessHollowing $proc.Id
        if ($hollow) {
            Write-Critical "Process HOLLOWING detected: $($proc.ProcessName) (PID $($proc.Id)) -- PEB ImageBase in PRIVATE memory"
            $hollowFindings.Add([PSCustomObject]@{ PID=$proc.Id; Name=$proc.ProcessName; Path=$ppath; Note="PEB ImageBase in PRIVATE memory" })
            Add-Finding "ProcessMemory" "ProcessHollowing" $proc.ProcessName "PID:$($proc.Id)" $null "Process Memory" 80
            Add-Timeline "CRITICAL: Process hollowing -- $($proc.ProcessName) PID $($proc.Id)"
            $hits++
        } else { Write-OK "$($proc.ProcessName) PID $($proc.Id) -- not hollowed" }
        Write-Host ""
    }

    Write-Info "Enumerating named pipes..."
    $pipes = Get-SuspiciousNamedPipes
    foreach ($pipe in $pipes) {
        Write-Critical "Suspicious pipe: \\.\pipe\$($pipe.PipeName) -- matches '$($pipe.Match)'"
        $pipeFindings.Add($pipe)
        Add-Finding "ProcessMemory" "SuspPipe" $pipe.PipeName $pipe.Match $null "Named Pipes" 45
        Add-Timeline "Cheat named pipe: $($pipe.PipeName)"
        $hits++
    }
    if ($pipes.Count -eq 0) { Write-OK "Named pipes: Clean" }

    Write-Info "Scanning for non-Roblox processes with Roblox handle..."
    $handles = Get-ProcessesWithRobloxHandle
    foreach ($h in $handles) {
        $cheatMatch = Test-CheatMatch $h.OwnerName.ToLower()
        $severity   = if ($cheatMatch) { 55 } else { 25 }
        Write-Critical "Handle: $($h.OwnerName) (PID $($h.OwnerPID)) holds handle to Roblox PID $($h.TargetPID) [VMRead=$($h.VMRead)] CheatMatch=$cheatMatch"
        $handleFindings.Add([PSCustomObject]@{ OwnerPID=$h.OwnerPID; OwnerName=$h.OwnerName; OwnerPath=$h.OwnerPath; TargetPID=$h.TargetPID; Access=$h.Access; VMRead=$h.VMRead; CheatMatch=$cheatMatch })
        Add-Finding "ProcessMemory" "RobloxHandle" $h.OwnerName "PID:$($h.OwnerPID)" $null "Process Memory" $severity
        if ($cheatMatch) { Add-Timeline "CRITICAL: Cheat process '$cheatMatch' has Roblox handle open" }
        $hits++
    }
    if ($handles.Count -eq 0) { Write-OK "Handle scan: No unexpected processes with Roblox open" }

    if ($hits -eq 0) { Write-OK "All memory checks: Clean" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# PAN SCAN -- Prefetch All Names (broad pass, all time)
# =====================================================
function Run-PANScan {
    Write-Header "PAN SCAN -- PREFETCH ALL NAMES (ALL TIME)" "Cyan"
    $hits = 0
    $pfPath = "C:\Windows\Prefetch"
    if (-not (Test-Path $pfPath)) {
        Write-Info "Prefetch directory not available"
        Write-SectionResult 0
        return 0
    }
    $pfFiles = @(Get-ChildItem $pfPath -Filter "*.pf" -File -Force -ErrorAction SilentlyContinue)
    Write-Info "Total prefetch files: $($pfFiles.Count)"
    foreach ($pf in $pfFiles) {
        $base = [System.IO.Path]::GetFileNameWithoutExtension($pf.Name)
        $exe  = if ($base -match '^(.+)-[0-9A-F]{8}$') { $Matches[1] } else { $base }
        if (Is-GlobalFP $exe) { continue }
        $match = Test-CheatMatch $exe.ToLower()
        if ($match) {
            $ts      = Get-PrefetchTimestamps $pf.FullName
            $lastRun = if ($ts.Count -gt 0) { $ts[0].ToString("yyyy-MM-dd HH:mm:ss") } else { $pf.LastWriteTime.ToString("yyyy-MM-dd HH:mm:ss") }
            Write-Hit "PAN HIT: $exe (last run: $lastRun) -- matches '$match'"
            Add-Finding "CheatArtifacts" "PANScan" $exe $match $null "Cheat Files Found" 35
            Add-Timeline "PAN: $exe matches '$match'"
            $hits++
        }
    }
    if ($hits -eq 0) { Write-OK "PAN scan: No cheat executables in prefetch (all time)" }
    Write-SectionResult $hits
    return $hits
}
# =====================================================
# KERNEL DRIVER SCAN
# =====================================================
function Run-KernelDriverScan {
    Write-Header "KERNEL DRIVER SCAN" "Cyan"
    $hits = 0

    $robloxStartTime = $null
    foreach ($rn in $robloxProcessNames) {
        $rproc = Get-Process -Name $rn -ErrorAction SilentlyContinue | Select-Object -First 1
        if ($rproc) { try { $robloxStartTime = $rproc.StartTime } catch {}; break }
    }
    if ($robloxStartTime) { Write-Info "Roblox started: $($robloxStartTime.ToString('yyyy-MM-dd HH:mm:ss')) -- flagging drivers within 5 min of this" }

    Write-Info "Scanning Event 7045 (new service installs)..."
    try {
        $events = Get-WinEvent -FilterHashtable @{ LogName="System"; Id=7045; StartTime=$script:ScanCutoff } -MaxEvents 500 -ErrorAction Stop
        foreach ($ev in $events) {
            $svcName = try { $ev.Properties[0].Value } catch { "" }
            $svcFile = try { $ev.Properties[1].Value } catch { "" }
            $svcType = try { $ev.Properties[3].Value } catch { "" }
            if (-not $svcName) { continue }
            $isKernel = $svcType -like "*kernel*" -or $svcType -like "*driver*" -or $svcType -eq "1"
            $checkStr = "$svcName $svcFile".ToLower()
            if (Is-GlobalFP $checkStr) { continue }

            $byovdMatch = $null
            foreach ($bd in $byovdDrivers) { if ($checkStr -like "*$bd*") { $byovdMatch = $bd; break } }
            $cheatMatch = Test-CheatMatch $checkStr
            $inTemp     = $svcFile -and ($svcFile.ToLower() -like "*\temp\*" -or $svcFile.ToLower() -like "*\appdata\*" -or $svcFile.ToLower() -like "*\downloads\*")
            $nearRoblox = $robloxStartTime -and [math]::Abs(($ev.TimeCreated - $robloxStartTime).TotalMinutes) -le 5

            if ($byovdMatch) {
                Write-KernelHit "Event 7045 BYOVD: '$svcName' matches '$byovdMatch' at $($ev.TimeCreated.ToString('yyyy-MM-dd HH:mm:ss'))"
                Add-Finding "KernelDrivers" "BYOVD-7045" $svcName $byovdMatch $null "Kernel Drivers" 70
                $kernelFindings.Add([PSCustomObject]@{ Type="BYOVD-Install"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Matched BYOVD list: $byovdMatch" })
                Add-Timeline "BYOVD driver install: $svcName"
                $hits++
            } elseif ($cheatMatch) {
                Write-KernelHit "Event 7045 cheat service: '$svcName' matches '$cheatMatch'"
                Add-Finding "KernelDrivers" "CheatService-7045" $svcName $cheatMatch $null "Kernel Drivers" 50
                $kernelFindings.Add([PSCustomObject]@{ Type="CheatService"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Cheat match: $cheatMatch" })
                $hits++
            } elseif ($isKernel -and $inTemp) {
                Write-Critical "DRIVER loaded from user-writable path: $svcName | $svcFile"
                Add-Finding "KernelDrivers" "KernelDriver-TempPath" $svcName $svcFile $null "Kernel Drivers" 70
                $kernelFindings.Add([PSCustomObject]@{ Type="TempPathDriver"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="LOADED FROM TEMP/USER PATH" })
                $hits++
            } elseif ($isKernel -and -not (Is-KnownLegitDriver $svcName)) {
                if ($nearRoblox) {
                    Write-KernelHit "Driver installed within 5 min of Roblox startup: $svcName"
                    Add-Finding "KernelDrivers" "KernelDriver-NearRoblox" $svcName $svcFile $null "Kernel Drivers" 35
                    $kernelFindings.Add([PSCustomObject]@{ Type="NearRoblox"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="LOADED WITHIN 5 MIN OF ROBLOX STARTUP" })
                    $hits++
                } else {
                    Write-Warn "Unknown kernel driver installed: $svcName ($svcFile)"
                    Add-Finding "KernelDrivers" "UnknownKernelDriver" $svcName $svcFile $null "Kernel Drivers" 15
                    $kernelFindings.Add([PSCustomObject]@{ Type="UnknownKernel"; Name=$svcName; File=$svcFile; Time=$ev.TimeCreated.ToString("yyyy-MM-dd HH:mm:ss"); Note="Unfamiliar driver -- verify manually" })
                }
            }
        }
        if ($hits -eq 0) { Write-OK "Event 7045: No suspicious driver installs" }
    } catch { Write-Info "Event 7045 scan skipped" }

    Write-Info "Enumerating currently loaded drivers..."
    $before = $hits
    try {
        $drivers = Get-WmiObject Win32_SystemDriver -ErrorAction Stop | Where-Object { $_.State -eq "Running" }
        foreach ($drv in $drivers) {
            $drvName = ($drv.Name -replace "\.sys$","").ToLower()
            $drvPath = $drv.PathName
            if (Is-KnownLegitDriver $drvName) { continue }
            if (Is-GlobalFP $drvPath) { continue }
            $byovdMatch = $null
            foreach ($bd in $byovdDrivers) {
                $isMatch = if ($bd.Length -le 5) { $drvName -eq $bd } else { $drvName -like "*$bd*" }
                if ($isMatch) { $byovdMatch = $bd; break }
            }
            $cleanPath = $drvPath -replace '\\\\?\\.\\','' -replace '"',''
            $sig = $null
            try { $sig = Get-AuthenticodeSignature $cleanPath -ErrorAction Stop } catch {}
            if ($sig -and $sig.SignerCertificate) {
                $thumb = $sig.SignerCertificate.Thumbprint
                if ($knownBadThumbs -contains $thumb) {
                    Write-Critical "KNOWN-ABUSED cert thumbprint: $drvName | $thumb"
                    Add-Finding "KernelDrivers" "AbusedCertDriver" $drvName $thumb $null "Kernel Drivers" 75
                    $kernelFindings.Add([PSCustomObject]@{ Type="AbusedCert"; Name=$drvName; File=$cleanPath; Time="NOW"; Note="KNOWN-ABUSED CERT: $thumb" })
                    $hits++
                }
                if ($sig.Status -eq "UnknownError" -or $sig.Status -eq "HashMismatch") {
                    Write-Critical "REVOKED/INVALID signature on driver: $drvName"
                    Add-Finding "KernelDrivers" "RevokedCertDriver" $drvName $sig.Status $null "Kernel Drivers" 70
                    $kernelFindings.Add([PSCustomObject]@{ Type="RevokedCert"; Name=$drvName; File=$cleanPath; Time="NOW"; Note="REVOKED/INVALID SIG: $($sig.Status)" })
                    $hits++
                }
            }
            if ($byovdMatch) {
                Write-Critical "LOADED BYOVD driver: $drvName ($drvPath)"
                Add-Finding "KernelDrivers" "BYOVD-Loaded" $drvName $drvPath $null "Kernel Drivers" 80
                $kernelFindings.Add([PSCustomObject]@{ Type="BYOVD-Loaded"; Name=$drvName; File=$drvPath; Time="NOW"; Note="Currently loaded BYOVD driver" })
                Add-Timeline "CRITICAL: BYOVD driver loaded: $drvName"
                $hits++
                continue
            }
            $cheatMatch = Test-CheatMatch $drvName
            if ($cheatMatch) {
                Write-Critical "LOADED DRIVER matches cheat: $drvName"
                Add-Finding "KernelDrivers" "LoadedDriver-CheatMatch" $drvName $drvPath $null "Kernel Drivers" 60
                $kernelFindings.Add([PSCustomObject]@{ Type="CheatDriver"; Name=$drvName; File=$drvPath; Time="NOW"; Note="CURRENTLY LOADED -- CHEAT MATCH: $cheatMatch" })
                Add-Timeline "Cheat driver loaded: $drvName"
                $hits++
                continue
            }
            if ($drvPath -and ($drvPath.ToLower() -like "*\temp\*" -or $drvPath.ToLower() -like "*\appdata\*")) {
                Write-Critical "DRIVER running from user-writable path: $drvName | $drvPath"
                Add-Finding "KernelDrivers" "LoadedDriver-TempPath" $drvName $drvPath $null "Kernel Drivers" 65
                $kernelFindings.Add([PSCustomObject]@{ Type="TempPathLoaded"; Name=$drvName; File=$drvPath; Time="NOW"; Note="RUNNING FROM USER-WRITABLE PATH" })
                $hits++
            }
        }
        if ($hits -eq $before) { Write-OK "Loaded driver check: Clean" }
    } catch { Write-Info "Driver enumeration skipped" }

    Write-SectionResult $hits
    return $hits
} 
# =====================================================
# LAUNCH CHAIN SCAN
# =====================================================
function Run-LaunchChainScan {
    Write-Header "ROBLOX LAUNCH CHAIN VALIDATION" "Cyan"
    $hits = 0

    $robloxProcs = @(Get-Process -ErrorAction SilentlyContinue |
        Where-Object { $robloxProcessNames -contains $_.ProcessName })

    if ($robloxProcs.Count -eq 0) {
        Write-Info "Roblox not running -- launch chain check skipped"
        Write-SectionResult 0
        return 0
    }

    $neutralParents = @("explorer","userinit","svchost","cmd","powershell","pwsh","wininit","winlogon","services","taskmgr","system")

    foreach ($proc in $robloxProcs) {
        Write-Host "  Checking: $($proc.ProcessName) PID $($proc.Id)" -ForegroundColor Cyan
        $chain = Get-ProcessAncestry $proc.Id
        foreach ($link in $chain) { Write-Info "    PID $($link.PID) -- $($link.Name) | $($link.Path)" }

        $procPath = try { $proc.MainModule.FileName } catch { "" }
        if ($procPath) {
            $isOfficial = $false
            foreach ($op in $officialRobloxPaths) { if ($procPath.ToLower().StartsWith($op.ToLower())) { $isOfficial = $true; break } }
            if (-not $isOfficial) {
                Write-LaunchHit "Roblox running from non-official path: $procPath"
                Add-Finding "LaunchChain" "NonOfficialPath" $procPath "" $null "Launch Chain" 50
                $launchChainFindings.Add([PSCustomObject]@{ RobloxProcess="$($proc.ProcessName) PID $($proc.Id)"; ParentName=""; ParentPath=$procPath; Note="NON-OFFICIAL INSTALL PATH" })
                Add-Timeline "Roblox non-official path: $procPath"
                $hits++
            } else { Write-OK "Roblox path is official: $procPath" }
        }

        $chainFlagged = $false
        for ($i = 1; $i -lt $chain.Count; $i++) {
            $parent     = $chain[$i]
            $parentName = if ($parent.Name) { $parent.Name.ToLower() } else { "" }
            $parentPath = if ($parent.Path) { $parent.Path.ToLower() } else { "" }

            $isKnownLauncher = $false
            foreach ($tpl in $knownThirdPartyLaunchers) {
                if ($parentName -like "*$($tpl.ToLower())*" -or $parentPath -like "*$($tpl.ToLower())*") {
                    Write-LaunchHit "3rd-party launcher in chain: $($parent.Name) | $($parent.Path)"
                    Add-Finding "LaunchChain" "ThirdPartyLauncher" $parent.Name $parent.Path $null "Launch Chain" 20
                    $launchChainFindings.Add([PSCustomObject]@{ RobloxProcess="$($chain[0].Name) PID $($chain[0].PID)"; ParentName=$parent.Name; ParentPath=$parent.Path; Note="3rd party launcher: $tpl" })
                    Add-Timeline "3rd party launcher: $($parent.Name)"
                    $isKnownLauncher = $true; $chainFlagged = $true; $hits++
                    break
                }
            }
            if ($isKnownLauncher) { break }

            $isNeutral = $neutralParents -contains $parentName -or ($neutralParents | Where-Object { $parentName -like "$_*" }).Count -gt 0

            if (-not $isNeutral -and $parentName -ne "") {
                $match = Test-CheatMatch $parentName
                if ($match) {
                    Write-Critical "CHEAT PROCESS in Roblox launch chain: $($parent.Name) matches '$match'"
                    Add-Finding "LaunchChain" "CheatInLaunchChain" $parent.Name $match $null "Launch Chain" 60
                    $launchChainFindings.Add([PSCustomObject]@{ RobloxProcess="$($chain[0].Name) PID $($chain[0].PID)"; ParentName=$parent.Name; ParentPath=$parent.Path; Note="CHEAT MATCH: $match" })
                    Add-Timeline "CRITICAL: Cheat launcher: $($parent.Name)"
                    $chainFlagged = $true; $hits++
                } else {
                    Write-Warn "Unexpected parent: $($parent.Name) ($($parent.Path))"
                    Add-Finding "LaunchChain" "UnexpectedParent" $parent.Name $parent.Path $null "Launch Chain" 10
                    $launchChainFindings.Add([PSCustomObject]@{ RobloxProcess="$($chain[0].Name) PID $($chain[0].PID)"; ParentName=$parent.Name; ParentPath=$parent.Path; Note="Unrecognized parent -- verify manually" })
                }
            }
        }
        if (-not $chainFlagged) { Write-OK "$($proc.ProcessName) PID $($proc.Id) -- launch chain clean" }
        Write-Host ""
    }

    if ($hits -eq 0) { Write-OK "Launch chain: No suspicious ancestry detected" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# ROBLOX LOG SCAN
# =====================================================
function Scan-RobloxLogs {
    Write-Header "ROBLOX LOG FILE SCAN" "Cyan"
    $hits    = 0
    $logRoot = "$env:LOCALAPPDATA\Roblox\logs"
    if (-not (Test-Path $logRoot)) {
        Write-Info "Roblox log directory not found"
        Write-SectionResult 0
        return 0
    }

    $logFiles = @(Get-ChildItem $logRoot -File -Filter "*.log" -ErrorAction SilentlyContinue |
        Where-Object { $script:ScanDaysBack -ge 9999 -or $_.LastWriteTime -ge $script:ScanCutoff } |
        Sort-Object LastWriteTime -Descending | Select-Object -First 50)

    Write-Info "Log files to scan: $($logFiles.Count)"
    $seen = [System.Collections.Generic.HashSet[string]]::new()
    foreach ($log in $logFiles) {
        try {
            $lines   = [System.IO.File]::ReadAllLines($log.FullName)
            $lineNum = 0
            foreach ($line in $lines) {
                $lineNum++
                $ll = $line.ToLower()
                $matchedMarker = $null
                foreach ($marker in $robloxLogCheatMarkers) {
                    if ($ll -like "*$($marker.ToLower())*") { $matchedMarker = $marker; break }
                }
                if ($matchedMarker) {
                    $key = "$($log.Name)|$matchedMarker"
                    if ($seen.Add($key)) {
                        $snippet = $line.Trim()
                        if ($snippet.Length -gt 120) { $snippet = $snippet.Substring(0,120) + "..." }
                        Write-Hit "Log [$($log.Name) L$lineNum] marker '$matchedMarker': $snippet"
                        Add-Finding "CheatArtifacts" "RobloxLog-Marker" "$($log.Name):L$lineNum" "$matchedMarker | $snippet" $null "Roblox Logs" 20
                        Add-Timeline "Roblox log marker '$matchedMarker' in $($log.Name)"
                        $hits++
                    }
                    continue
                }
                $m = Test-CheatMatch $ll
                if ($m) {
                    $key = "$($log.Name)|term|$m"
                    if ($seen.Add($key)) {
                        $snippet = $line.Trim()
                        if ($snippet.Length -gt 120) { $snippet = $snippet.Substring(0,120) + "..." }
                        Write-Hit "Log [$($log.Name) L$lineNum] cheat term '$m': $snippet"
                        Add-Finding "CheatArtifacts" "RobloxLog-CheatTerm" "$($log.Name):L$lineNum" "$m | $snippet" $null "Roblox Logs" 25
                        $hits++
                    }
                }
            }
        } catch { continue }
    }
    if ($hits -eq 0) { Write-OK "Roblox logs: Clean" }
    Write-SectionResult $hits
    return $hits
}

# =====================================================
# AMCACHE SCAN (via VSS)
# =====================================================
function Run-AmCacheScan {
    Write-Header "AMCACHE SCAN (via VSS)" "Cyan"
    $hits = 0

    $shadow = Get-WmiObject Win32_ShadowCopy -ErrorAction SilentlyContinue |
        Sort-Object InstallDate -Descending | Select-Object -First 1

    if (-not $shadow) {
        Write-Info "No VSS shadow copies found -- AmCache scan skipped"
        Write-Info "AmCache.hve is locked by the OS while Windows is running; this requires a shadow copy"
        Write-SectionResult 0
        return 0
    }

    $hiveShadow = "$($shadow.DeviceObject)\Windows\AppCompat\Programs\Amcache.hve"
    $mountKey   = "HKLM\TempAmCache_CheatScan"
    $mountPath  = "HKLM:\TempAmCache_CheatScan"
    $mounted    = $false

    try {
        Write-Info "Shadow copy found: $($shadow.InstallDate)"
        Write-Info "Mounting AmCache hive..."
        $regResult = reg load $mountKey $hiveShadow 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Warn "Failed to mount AmCache hive: $regResult"
            Write-SectionResult 0
            return 0
        }
        $mounted = $true

        $appFilePath = "$mountPath\Root\InventoryApplicationFile"
        if (Test-Path $appFilePath) {
            $entries = Get-ChildItem $appFilePath -ErrorAction SilentlyContinue
            Write-Info "AmCache entries: $($entries.Count)"
            foreach ($entry in $entries) {
                try {
                    $props = Get-ItemProperty $entry.PSPath -ErrorAction SilentlyContinue
                    $name  = $props.Name
                    $path  = $props.LowerCaseLongPath
                    if (-not $name -and -not $path) { continue }
                    $checkStr = "$name $path".ToLower()
                    if (Is-GlobalFP $checkStr) { continue }
                    $match = Test-CheatMatch $checkStr
                    if ($match) {
                        Write-Hit "AmCache HIT: '$name' at '$path' (matched '$match')"
                        Add-Finding "CheatArtifacts" "AmCache-Hit" $name $path $null "Cheat Files Found" 35
                        Add-Timeline "AmCache hit: $name"
                        $hits++
                    }
                } catch { continue }
            }
        } else { Write-Info "InventoryApplicationFile key not found in shadow hive" }

        $drvPath = "$mountPath\Root\InventoryDriverBinary"
        if (Test-Path $drvPath) {
            foreach ($entry in (Get-ChildItem $drvPath -ErrorAction SilentlyContinue)) {
                try {
                    $props   = Get-ItemProperty $entry.PSPath -ErrorAction SilentlyContinue
                    $drvName = ($props.DriverName -replace "\.sys$","").ToLower()
                    if ($drvName -and $byovdDrivers -contains $drvName) {
                        Write-KernelHit "AmCache BYOVD driver remnant: '$drvName'"
                        Add-Finding "KernelDrivers" "AmCache-BYOVD" $drvName "" $null "Kernel Drivers" 50
                        $hits++
                    }
                } catch { continue }
            }
        }

        if ($hits -eq 0) { Write-OK "AmCache: No cheat artifacts found" }
    } catch {
        Write-Warn "AmCache scan error: $_"
    } finally {
        if ($mounted) {
            [GC]::Collect()
            Start-Sleep -Milliseconds 500
            reg unload $mountKey 2>&1 | Out-Null
            if ($LASTEXITCODE -ne 0) { Write-Warn "AmCache hive did not unmount cleanly -- a reboot will clear it" }
        }
    }

    Write-SectionResult $hits
    return $hits
}

# =====================================================
# FINDINGS SUMMARY
# =====================================================
function Show-FindingsSummary {
    Write-Header "FINDINGS SUMMARY" "Magenta"
    $totalHits = 0
    foreach ($cat in $findings.Keys) {
        $count = $findings[$cat].Count
        if ($count -gt 0 -and $cat -ne "FalsePositives") {
            Write-Host "  $cat : $count finding(s)" -ForegroundColor Magenta
            $totalHits += $count
        }
    }
    Write-Host ""
    Write-Host "  Total findings : $totalHits" -ForegroundColor $(if ($totalHits -gt 0) { "Magenta" } else { "Green" })
    Write-Host "  False positives excluded: $($findings['FalsePositives'].Count)" -ForegroundColor DarkGray
    Write-Host ""
    Read-Host "  Press ENTER to continue to scores"
}

# =====================================================
# SCORES
# =====================================================
function Show-Scores {
    Write-Header "SCORES" "Cyan"
    Write-Host "  -- SYSTEM CONFIGURATION --" -ForegroundColor DarkCyan
    foreach ($k in $configScores.Keys) {
        $v   = $configScores[$k]
        $col = if ($v -ge 80) { "Green" } elseif ($v -ge 50) { "Yellow" } else { "Red" }
        Write-Host "    $k : $v / 100" -ForegroundColor $col
    }
    Write-Host ""
    Write-Host "  -- CHEAT EVIDENCE --" -ForegroundColor DarkCyan
    foreach ($k in $cheatScores.Keys) {
        $v   = $cheatScores[$k]
        $col = if ($v -ge 80) { "Green" } elseif ($v -ge 50) { "Yellow" } else { "Red" }
        Write-Host "    $k : $v / 100" -ForegroundColor $col
    }

    $configAvg = [math]::Round(($configScores.Values | Measure-Object -Average).Average, 1)
    $cheatAvg  = [math]::Round(($cheatScores.Values  | Measure-Object -Average).Average, 1)
    Write-Host ""
    Write-Host "  +-----------------------------------------+" -ForegroundColor Cyan
    Write-Host "  | CONFIG SCORE : $configAvg / 100" -ForegroundColor $(if ($configAvg -ge 80) { "Green" } elseif ($configAvg -ge 50) { "Yellow" } else { "Red" })
    Write-Host "  | CHEAT SCORE  : $cheatAvg / 100"  -ForegroundColor $(if ($cheatAvg  -ge 80) { "Green" } elseif ($cheatAvg  -ge 50) { "Yellow" } else { "Red" })
    if     ($cheatAvg -ge 90) { Write-Host "  | VERDICT: No cheat evidence found." -ForegroundColor Green }
    elseif ($cheatAvg -ge 70) { Write-Host "  | VERDICT: Minor suspicious activity -- review findings." -ForegroundColor Yellow }
    elseif ($cheatAvg -ge 40) { Write-Host "  | VERDICT: Suspicious -- likely cheat activity detected." -ForegroundColor Red }
    else                      { Write-Host "  | VERDICT: HIGH CONFIDENCE -- significant cheat evidence." -ForegroundColor Red }
    Write-Host "  +-----------------------------------------+" -ForegroundColor Cyan
    Write-Host ""
    Read-Host "  Press ENTER to continue"
    return @{ Config = $configAvg; Cheat = $cheatAvg }
}

